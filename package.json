{
	"name": "ddlawson.com",
	"description": "Personal portfolio site built with Astro and Tailwind CSS.",
	"type": "module",
	"version": "0.0.1",
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro check && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "biome check .",
		"fix": "biome check --write .",
		"fix:unsafe": "biome check --write .",
		"format": "biome format --write .",
		"types": "astro sync && tsc --noEmit",
		"generate:og": "bun scripts/generate-og-images.ts"
	},
	"dependencies": {
		"@astrojs/sitemap": "^3.7.2",
		"@iconify-json/tabler": "^1.2.33",
		"astro": "^6.1.8",
		"astro-favicons": "^3.1.6",
		"astro-icon": "^1.1.5"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.8",
		"@astrojs/compiler-rs": "^0.1.6",
		"@biomejs/biome": "2.4.10",
		"@cloudflare/workers-types": "^4.20260410.1",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"lefthook": "^2.1.5",
		"playwright": "^1.59.1",
		"sharp": "^0.34.5",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.5"
	},
	"packageManager": "pnpm@10.33.0",
	"pnpm": {
		"supportedArchitectures": {
			"os": [
				"darwin",
				"linux"
			],
			"cpu": [
				"x64",
				"arm64"
			],
			"libc": [
				"glibc",
				"musl"
			]
		}
	}
}
