---
import HeroImageFull from '@/assets/images/david-d-lawson-full.png';
import Button from '@/components/Button.astro';
import Divider from '@/components/Divider.astro';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import SectionEyebrow from '@/components/SectionEyebrow.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/site.config';
import { Image } from 'astro:assets';

const meta = {
  title: 'About',
  description: SITE.description,
  canonical: SITE.origin + '/about',
};
---

<BaseLayout {meta}>
  <Header />

  <!-- ─── Hero ─────────────────────────────────────────────────────────── -->
  <section class="relative min-h-screen overflow-hidden bg-bg">
    <div class="grid h-full min-h-screen grid-cols-[1fr_1fr] max-[900px]:grid-cols-1">
      <!-- Photo side -->
      <div class="relative min-h-[60vh] overflow-hidden max-[900px]:order-1 max-[900px]:h-[65vw] max-[900px]:min-h-0">
        <!-- Blue glow underneath photo -->
        <div class="absolute right-0 bottom-0 left-0 z-10 h-1/3 bg-gradient-to-t from-accent/20 to-transparent"></div>
        <!-- Fade to bg at bottom -->
        <div class="absolute right-0 bottom-0 left-0 z-20 h-2/5 bg-gradient-to-t from-bg to-transparent"></div>
        <!-- Right edge fade -->
        <div class="absolute inset-y-0 right-0 z-10 w-1/4 bg-gradient-to-l from-bg to-transparent max-[900px]:hidden">
        </div>
        <Image
          src={HeroImageFull}
          alt="David D Lawson"
          format="webp"
          width={900}
          height={1200}
          class="h-full w-full object-cover object-top"
        />
      </div>

      <!-- Text side -->
      <div
        class="relative flex flex-col justify-center px-16 py-32 max-[900px]:order-2 max-[900px]:px-8 max-[900px]:py-16 max-sm:px-6 max-sm:py-12"
      >
        <!-- Ghost text backdrop -->
        <span
          class="pointer-events-none absolute top-1/2 right-0 -translate-y-1/2 font-display text-[clamp(8rem,18vw,18rem)] leading-none font-extrabold text-text opacity-[0.03] select-none max-[900px]:top-4 max-[900px]:translate-y-0"
          aria-hidden="true">ABOUT</span
        >

        <div class="relative z-10">
          <!-- Eyebrow -->
          <div class="animate-fade-up opacity-0" style="animation-delay: 100ms; animation-fill-mode: forwards;">
            <SectionEyebrow text="The Story So Far" />
          </div>

          <!-- Name -->
          <h1
            class="mt-4 animate-fade-up font-display text-display leading-[0.92] font-extrabold text-text opacity-0"
            style="animation-delay: 250ms; animation-fill-mode: forwards;"
          >
            David D.<br />Lawson
          </h1>

          <!-- Accent rule -->
          <div
            class="mt-8 h-px w-[100px] animate-fade-up bg-accent opacity-0"
            style="animation-delay: 400ms; animation-fill-mode: forwards;"
          >
          </div>

          <!-- Location -->
          <p
            class="mt-6 animate-fade-up font-body text-caption tracking-widest text-text-muted uppercase opacity-0"
            style="animation-delay: 550ms; animation-fill-mode: forwards;"
          >
            London, United Kingdom
          </p>
        </div>
      </div>
    </div>
  </section>

  <Divider />

  <!-- ─── Bio ──────────────────────────────────────────────────────────── -->
  <section class="relative bg-surface px-12 py-28 max-sm:px-6 max-sm:py-16">
    <SectionEyebrow text="Background" sideways />
    <div
      class="ml-6 grid grid-cols-[1fr_1.4fr] items-start gap-20 max-[900px]:ml-0 max-[900px]:grid-cols-1 max-[900px]:gap-10"
    >
      <!-- Pull quote -->
      <div class="reveal">
        <blockquote class="font-display text-heading leading-snug font-bold text-text italic">
          "I believe every problem presents an opportunity."
        </blockquote>
        <div class="mt-6 h-px w-16 bg-accent"></div>
      </div>

      <!-- Bio paragraphs -->
      <div class="reveal space-y-6 font-body text-body leading-relaxed font-light text-text-secondary">
        <p>
          Customer Success leader at <strong class="font-semibold text-text">Wiz</strong> — the cloud security company rewriting
          how enterprises think about risk.
        </p>
        <p>
          Before Wiz: navigating the messy, human side of B2B SaaS adoption at scale across <strong
            class="font-semibold text-text">Veracode</strong
          >, <strong class="font-semibold text-text">Lacework</strong>, and <strong class="font-semibold text-text"
            >Finalsite</strong
          >.
        </p>
        <p>
          Outside work, I chase the edges of what AI makes possible — building tools, writing about what I learn, and
          trying to leave something useful behind.
        </p>
      </div>
    </div>
  </section>

  <Divider />

  <!-- ─── Stats ribbon ──────────────────────────────────────────────────── -->
  <section class="bg-bg py-16">
    <div class="px-12 max-sm:px-6">
      <div
        class="grid grid-cols-4 divide-x divide-border max-[700px]:grid-cols-2 max-[700px]:gap-y-10 max-[700px]:divide-x-0"
      >
        <div class="reveal flex flex-col items-center gap-2 px-8 text-center max-[700px]:px-4">
          <span class="font-display text-heading font-extrabold text-text">10+</span>
          <span class="font-body text-caption tracking-widest text-text-muted uppercase">Years in SaaS</span>
        </div>

        <div class="reveal flex flex-col items-center gap-2 px-8 text-center max-[700px]:px-4">
          <span class="font-display text-heading font-extrabold text-text">5</span>
          <span class="font-body text-caption tracking-widest text-text-muted uppercase">Companies</span>
        </div>

        <div class="reveal flex flex-col items-center gap-2 px-8 text-center max-[700px]:px-4">
          <span class="font-display text-heading font-extrabold text-text">Cloud Security</span>
          <span class="font-body text-caption tracking-widest text-text-muted uppercase">Current Focus</span>
        </div>

        <div class="reveal flex flex-col items-center gap-2 px-8 text-center max-[700px]:px-4">
          <span class="font-display text-heading font-extrabold text-text">London</span>
          <span class="font-body text-caption tracking-widest text-text-muted uppercase">Based In</span>
        </div>
      </div>
    </div>
  </section>

  <Divider />

  <!-- ─── Interests ─────────────────────────────────────────────────────── -->
  <section class="relative bg-surface px-12 py-28 max-sm:px-6 max-sm:py-16">
    <SectionEyebrow text="Beyond Work" sideways />
    <div class="ml-6 max-[900px]:ml-0">
      <div class="mb-14">
        <SectionEyebrow text="Beyond Work" />
      </div>
      <div class="grid grid-cols-3 gap-12 max-[900px]:grid-cols-1 max-[900px]:gap-8">
        <div class="reveal">
          <span class="mb-4 block font-body text-caption font-semibold tracking-widest text-accent uppercase">01</span>
          <h3 class="font-display text-subheading font-bold text-text">AI & LLMs</h3>
          <div class="mt-3 h-px w-8 bg-border"></div>
          <p class="mt-5 font-body text-body leading-relaxed font-light text-text-secondary">
            Experimenting with language models daily. Not to automate, but to think faster and build better.
          </p>
        </div>

        <div class="reveal">
          <span class="mb-4 block font-body text-caption font-semibold tracking-widest text-accent uppercase">02</span>
          <h3 class="font-display text-subheading font-bold text-text">Writing</h3>
          <div class="mt-3 h-px w-8 bg-border"></div>
          <p class="mt-5 font-body text-body leading-relaxed font-light text-text-secondary">
            500 words a day. The internet is the most leveraged writing desk ever built.
          </p>
        </div>

        <div class="reveal">
          <span class="mb-4 block font-body text-caption font-semibold tracking-widest text-accent uppercase">03</span>
          <h3 class="font-display text-subheading font-bold text-text">Building Things</h3>
          <div class="mt-3 h-px w-8 bg-border"></div>
          <p class="mt-5 font-body text-body leading-relaxed font-light text-text-secondary">
            From this website to small tools — the joy is in making something from nothing.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Divider />

  <!-- ─── CTA ───────────────────────────────────────────────────────────── -->
  <section class="relative bg-bg px-12 py-28 max-sm:px-6 max-sm:py-16">
    <div class="reveal ml-6 max-w-[700px] max-[900px]:ml-0">
      <h2 class="font-display text-display leading-[0.92] font-extrabold text-text">Let's Connect</h2>
      <div class="mt-6 h-px w-[100px] bg-accent"></div>
      <p class="mt-8 font-body text-body leading-relaxed font-light text-text-secondary">
        I'm always open to conversations about technology, customer success, or interesting ideas.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <Button title="Get In Touch" link="/contact" variant="primary" size="lg" icon="tabler:mail" />
        <Button title="View My Work" link="/work" variant="outline" size="lg" icon="tabler:briefcase" />
      </div>
    </div>
  </section>

  <Footer />

  <script src="../scripts/reveal.ts"></script>
</BaseLayout>
