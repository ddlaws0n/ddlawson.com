---
import HeroImage from '@/assets/images/david-d-lawson-profile-full.png';
import Button from '@/components/Button.astro';
import Divider from '@/components/Divider.astro';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import SectionEyebrow from '@/components/SectionEyebrow.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/site.config';
import { Image } from 'astro:assets';

const meta = {
  title: 'About',
  description: SITE.description,
  canonical: SITE.origin + '/about',
};
---

<BaseLayout {meta}>
  <Header />

  <!-- Hero -->
  <section class="relative bg-bg px-12 py-24 max-sm:px-6 max-sm:py-16">
    <SectionEyebrow text="About" sideways />
    <div
      class="ml-6 grid grid-cols-[0.8fr_1.2fr] items-center gap-24 max-[900px]:ml-0 max-[900px]:grid-cols-1 max-[900px]:gap-12"
    >
      <!-- Display type -->
      <div class="reveal">
        <span
          class="block font-display text-[clamp(5rem,10vw,11rem)] leading-[0.88] font-extrabold text-text opacity-[0.06]"
          >The</span
        >
        <span class="block font-display text-[clamp(5rem,10vw,11rem)] leading-[0.88] font-extrabold text-text"
          >Story</span
        >
      </div>
      <!-- Image -->
      <div class="reveal relative h-[480px] overflow-hidden rounded-xl lg:h-[600px]">
        <div class="absolute inset-0 bg-gradient-to-tr from-accent/10 to-transparent mix-blend-overlay"></div>
        <Image
          src={HeroImage}
          alt="David D Lawson"
          format="webp"
          width={640}
          height={960}
          class="h-full w-full object-cover object-top"
        />
      </div>
    </div>
  </section>

  <Divider />

  <!-- Bio -->
  <section class="relative bg-surface px-12 py-24 max-sm:px-6 max-sm:py-16">
    <SectionEyebrow text="Background" sideways />
    <div class="ml-6 max-w-[680px] max-[900px]:ml-0">
      <SectionEyebrow text="Background" />
      <div class="reveal space-y-6 font-body text-[1.05rem] leading-relaxed font-light text-text-secondary">
        <p>
          Hey, I'm David. I currently work as the <strong class="font-medium text-text">Customer Success</strong> manager
          at
          <strong class="font-medium text-text">Wiz</strong>, where my focus is on helping customers maximise the return
          on their efforts to secure their cloud estate. I also champion the Voice of the Customer and take an
          uncompromisingly data-driven approach to improving the overall customer experience.
        </p>
        <p>
          Outside of work, I have a keen interest in many different creative pursuits, from music and filmography to
          writing and building things — both physical and digital. I'm an avid traveller and occasional fitness
          enthusiast.
        </p>
        <p>
          I'm also <strong class="font-medium text-text">passionate</strong> about generative AI, LLMs and transformer technologies
          and their potential to positively impact the world.
        </p>
      </div>
    </div>
  </section>

  <Divider />

  <!-- Work CTA -->
  <section class="relative bg-bg px-12 py-24 max-sm:px-6 max-sm:py-16">
    <SectionEyebrow text="Experience" sideways />
    <div class="ml-6 max-[900px]:ml-0">
      <SectionEyebrow text="Experience" />
      <div class="reveal flex flex-col items-start gap-8 max-[600px]:gap-6">
        <p class="max-w-[520px] font-body text-[1.05rem] leading-relaxed font-light text-text-secondary">
          A career built at the intersection of technology and human outcomes — from early-stage SaaS to enterprise
          cloud security.
        </p>
        <div class="flex flex-wrap gap-4">
          <Button title="View Work History" link="/work" variant="primary" size="lg" icon="tabler:briefcase" />
          <Button
            title="Connect on LinkedIn"
            link={SITE.socialShares.find((s) => s.name === 'LinkedIn')?.link ?? 'https://www.linkedin.com/in/ddlawson/'}
            variant="outline"
            size="lg"
            icon="tabler:brand-linkedin"
            target="_blank"
            rel="noopener noreferrer"
            umami="linkedin-connect-about"
          />
        </div>
      </div>
    </div>
  </section>

  <Footer />

  <script src="../scripts/reveal.ts"></script>
</BaseLayout>
