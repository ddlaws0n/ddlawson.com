---
import Button from '@/components/Button.astro';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout>
  <Header />

  <main class="flex grow flex-col items-center justify-center px-6 py-32 text-center">
    <p
      class="font-display text-[clamp(6rem,20vw,14rem)] leading-none font-bold text-text opacity-5 select-none"
      aria-hidden="true"
    >
      404
    </p>
    <h1 class="-mt-4 font-display text-subheading font-bold text-text">Page Not Found</h1>
    <p class="mt-4 max-w-[40ch] font-body text-body text-text-secondary">
      The page you're looking for doesn't exist or may have been moved.
    </p>
    <div class="mt-10">
      <Button title="Take me home" link="/" icon="tabler:home" variant="primary" size="md" />
    </div>
  </main>

  <Footer />
</BaseLayout>
