---
import { Icon } from "astro-icon/components";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  meta={{
    title: "404 — Page Not Found",
    description: "This page doesn't exist.",
    noindex: true,
    nofollow: true,
  }}
>
  <div class="font-body bg-background text-text relative h-dvh overflow-hidden">
    <div class="m-noise"></div>

    <!-- Ambient glow -->
    <div
      class="pointer-events-none absolute top-1/2 left-1/2 size-[60vmin] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[radial-gradient(ellipse,color-mix(in_oklch,var(--color-teal)_6%,transparent)_0%,transparent_65%)]"
      aria-hidden="true"
    >
    </div>

    <!-- Second offset glow -->
    <div
      class="pointer-events-none absolute top-[30%] right-[15%] size-[35vmin] rounded-full bg-[radial-gradient(ellipse,color-mix(in_oklch,var(--color-teal)_3%,transparent)_0%,transparent_60%)]"
      aria-hidden="true"
    >
    </div>

    <main
      id="main-content"
      class="relative z-10 flex h-full flex-col items-center justify-center px-(--m-gutter) text-center"
    >
      <!-- Large 404 number -->
      <div class="animate-fade-up opacity-0 motion-reduce:opacity-100">
        <span
          class="font-display text-display text-text/4 block font-extralight tracking-[-0.04em] select-none"
          aria-hidden="true"
        >
          404
        </span>
      </div>

      <!-- Overlaid content -->
      <div
        class="animate-fade-up -mt-[clamp(4rem,10vw,8rem)] opacity-0 motion-reduce:opacity-100 [animation-delay:0.15s]"
      >
        <span
          class="font-display text-teal-muted text-label mb-3 block font-semibold tracking-[0.24em] uppercase"
        >
          Page Not Found
        </span>
        <h1
          class="font-display text-quote text-text mx-auto max-w-[14ch] font-bold tracking-[-0.02em]"
        >
          Nothing lives here<span class="text-teal">.</span>
        </h1>
        <p
          class="font-body text-prose text-text-secondary mx-auto mt-4 mb-0 max-w-[32ch] font-light"
        >
          The page you're looking for has moved, been renamed, or never existed
          in the first place.
        </p>
      </div>

      <!-- CTA -->
      <div
        class="animate-fade-up mt-8 opacity-0 motion-reduce:opacity-100 [animation-delay:0.3s] lg:mt-10"
      >
        <a
          href="/"
          class="group font-display text-teal hover:text-teal-bright inline-flex items-center gap-2 text-sm font-medium tracking-[0.06em] uppercase no-underline transition-all duration-300 hover:gap-3"
        >
          <span
            class="border-teal/30 group-hover:border-teal group-hover:bg-teal/8 inline-flex size-8 items-center justify-center rounded-full border transition-all duration-300"
          >
            <Icon name="tabler:arrow-left" class="size-3.5" />
          </span>
          Back to Home
        </a>
        <div class="mt-6 flex items-center justify-center gap-4 text-caption text-text-muted">
          <a href="/work" class="hover:text-teal inline-flex min-h-11 min-w-11 items-center justify-center p-2.5 no-underline transition-colors duration-250">Work</a>
          <span class="text-border">·</span>
          <a href="/writing" class="hover:text-teal inline-flex min-h-11 min-w-11 items-center justify-center p-2.5 no-underline transition-colors duration-250">Writing</a>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>
