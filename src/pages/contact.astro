---
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, SOCIAL } from '@/site.config';
import { Icon } from 'astro-icon/components';
import { actions } from 'astro:actions';

const meta = {
  title: 'Contact',
  description: "Get in touch — whether it's about customer success, AI, building something, or just swapping notes.",
  canonical: SITE.origin + '/contact',
};

const result = Astro.getActionResult(actions.submitContactForm);
const isSuccess = !!result && !result.error;
const isError = !!result && !!result.error;

let fieldErrors: Record<string, string[] | undefined> = {};
if (result?.error && 'fields' in result.error && result.error.fields) {
  fieldErrors = result.error.fields as Record<string, string[] | undefined>;
}

const generalErrorMessage = result?.error?.message;

let statusMessage: string | null = null;
if (isSuccess) {
  statusMessage = "Message sent. I'll be in touch soon.";
} else if (generalErrorMessage) {
  statusMessage = generalErrorMessage;
} else if (isError && Object.keys(fieldErrors).length > 0) {
  statusMessage = 'Please correct the errors highlighted below.';
}
---

<BaseLayout {meta}>
  <Header />

  <main class="min-h-screen w-full">
    <div class="signal-grid">
      {/* ─── Left — The Intro ─────────────────────────────────────── */}
      <div class="signal-left relative flex flex-col justify-between overflow-hidden bg-bg p-6 md:p-12">
        {/* Ghost text */}
        <span
          class="pointer-events-none absolute -bottom-8 left-0 font-display text-ghost leading-none font-extrabold tracking-tighter text-text opacity-ghost select-none"
          aria-hidden="true"
        >
          HELLO
        </span>

        <div class="relative z-10 flex flex-col gap-10">
          <div>
            <p class="hero-eyebrow font-display text-caption font-semibold tracking-wide text-text-muted uppercase">
              Get In Touch
            </p>

            <div class="mt-6 flex flex-col">
              <span
                class="line line-1 font-display text-display leading-none font-extrabold text-text opacity-watermark"
              >
                Say
              </span>
              <span class="line line-2 font-display text-display leading-none font-extrabold text-text"> Hello. </span>
            </div>

            <div class="hero-rule mt-8 h-0.5 w-[100px] bg-accent"></div>

            <p class="hero-desc mt-8 max-w-sm font-body text-body leading-relaxed font-light text-text-secondary">
              I'm always up for a good conversation — whether it's about customer success, AI, building something from
              scratch, or an idea you can't stop thinking about.
            </p>
          </div>

          {/* Social links */}
          <div class="hero-desc flex flex-wrap gap-6">
            {
              SOCIAL.map(({ link, ariaLabel }) => (
                <a
                  href={link}
                  target="_blank"
                  rel="me noopener noreferrer"
                  aria-label={ariaLabel}
                  class="font-body text-caption text-text-muted transition-colors duration-200 hover:text-accent"
                >
                  {ariaLabel}
                </a>
              ))
            }
          </div>
        </div>
      </div>

      {/* ─── Right — The Form ─────────────────────────────────────── */}
      <div class="reveal bg-surface p-6 md:p-12">
        {/* Status message */}
        {
          statusMessage && (
            <div
              class:list={[
                'mb-8 rounded-md border px-4 py-3 text-sm font-medium',
                { 'border-green-500/30 bg-green-500/10 text-green-400': isSuccess },
                { 'border-red-500/30 bg-red-500/10 text-red-400': isError },
                { 'border-accent/30 bg-accent/10 text-accent': !isSuccess && !isError },
              ]}
            >
              {statusMessage}
            </div>
          )
        }

        <form id="contact-form" method="POST" action="/contact?_action=submitContactForm" class="space-y-6">
          {/* Name + Email grid */}
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            <div>
              <label
                for="name"
                class="mb-3 block font-display text-caption font-semibold tracking-label text-text-muted uppercase"
              >
                Name
              </label>
              <div class="relative">
                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                  <Icon name="tabler:user" class="size-5 text-text-muted" />
                </div>
                <input
                  type="text"
                  id="name"
                  name="name"
                  class:list={[
                    'block w-full rounded-md border bg-elevated px-10 py-3.5 font-body text-body text-text transition-colors duration-200 placeholder:text-text-muted/60 focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none',
                    fieldErrors.name ? 'border-red-500' : 'border-border',
                  ]}
                  placeholder="Your name"
                  autocomplete="name"
                  required
                  transition:persist
                />
              </div>
              {fieldErrors.name && <p class="mt-1 text-small text-red-400">{fieldErrors.name.join(', ')}</p>}
            </div>

            <div>
              <label
                for="email"
                class="mb-3 block font-display text-caption font-semibold tracking-label text-text-muted uppercase"
              >
                Email
              </label>
              <div class="relative">
                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                  <Icon name="tabler:mail" class="size-5 text-text-muted" />
                </div>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class:list={[
                    'block w-full rounded-md border bg-elevated px-10 py-3.5 font-body text-body text-text transition-colors duration-200 placeholder:text-text-muted/60 focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none',
                    fieldErrors.email ? 'border-red-500' : 'border-border',
                  ]}
                  placeholder="you@example.com"
                  autocomplete="email"
                  spellcheck="false"
                  required
                  transition:persist
                />
              </div>
              {fieldErrors.email && <p class="mt-1 text-small text-red-400">{fieldErrors.email.join(', ')}</p>}
            </div>
          </div>

          {/* Message */}
          <div>
            <label
              for="message"
              class="mb-3 block font-display text-caption font-semibold tracking-label text-text-muted uppercase"
            >
              Message
            </label>
            <div class="relative">
              <div class="pointer-events-none absolute top-3 left-0 flex items-start pt-1 pl-3">
                <Icon name="tabler:message" class="size-5 text-text-muted" />
              </div>
              <textarea
                id="message"
                name="message"
                rows="6"
                class:list={[
                  'block w-full resize-y rounded-md border bg-elevated px-10 py-3.5 font-body text-body text-text transition-colors duration-200 placeholder:text-text-muted/60 focus:border-accent focus:ring-1 focus:ring-accent focus:outline-none',
                  fieldErrors.message ? 'border-red-500' : 'border-border',
                ]}
                placeholder="What's on your mind?"
                required
                transition:persist></textarea>
            </div>
            {fieldErrors.message && <p class="mt-1 text-small text-red-400">{fieldErrors.message.join(', ')}</p>}
          </div>

          {/* Turnstile */}
          <div>
            <div
              id="turnstile-widget"
              class="my-2"
              data-sitekey={import.meta.env.PUBLIC_CAPTCHA_SITE_KEY}
              transition:persist="turnstile-widget"
            >
            </div>
            <input type="hidden" name="captchaToken" id="captchaToken" transition:persist />
          </div>

          {/* Turnstile Widget Loader Script */}
          <script is:inline>
            document.addEventListener('astro:page-load', () => {
              if (!window.turnstile) {
                if (!document.querySelector('script[src="https://challenges.cloudflare.com/turnstile/v0/api.js"]')) {
                  const script = document.createElement('script');
                  script.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
                  script.async = true;
                  script.defer = true;
                  document.head.appendChild(script);
                  script.onload = renderTurnstile;
                }
              } else {
                renderTurnstile();
              }

              function renderTurnstile() {
                const widgetContainer = document.getElementById('turnstile-widget');
                if (window.turnstile && widgetContainer && !widgetContainer.querySelector('.cf-turnstile')) {
                  window.turnstile.render('#turnstile-widget', {
                    sitekey: widgetContainer.dataset.sitekey,
                    callback: function (token) {
                      const tokenInput = document.getElementById('captchaToken');
                      if (tokenInput) {
                        tokenInput.value = token;
                      }
                    },
                    'error-callback': function () {
                      console.error('Turnstile error: Failed to render widget.');
                    },
                    'expired-callback': function () {
                      const tokenInput = document.getElementById('captchaToken');
                      if (tokenInput) {
                        tokenInput.value = '';
                      }
                    },
                  });
                }
              }
            });
          </script>

          {/* Submit */}
          <div class="flex flex-col gap-3 pt-2">
            <button
              type="submit"
              class="flex w-full items-center justify-center gap-2 rounded-md bg-accent px-8 py-3.5 font-display text-small font-semibold tracking-wide text-bg uppercase transition-colors duration-200 hover:bg-accent-bright"
            >
              Send Message
              <Icon name="tabler:send" class="size-4" />
            </button>
            <p class="text-center font-body text-caption text-text-muted opacity-half">
              Protected by Cloudflare Turnstile
            </p>
          </div>
        </form>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .signal-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    min-height: 100vh;
    min-height: 100dvh;
  }

  .signal-left {
    position: sticky;
    top: 0;
    height: 100vh;
  }

  /* ——— Hero animations ——— */
  .hero-eyebrow {
    opacity: 0;
    animation: fadeUp 0.6s ease forwards;
    animation-delay: 0.15s;
  }

  .line {
    display: block;
    clip-path: inset(100% 0 0 0);
    animation: clipReveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .line-1 {
    animation-delay: 0.25s;
  }
  .line-2 {
    animation-delay: 0.42s;
  }

  .hero-rule {
    opacity: 0;
    transform: scaleX(0);
    transform-origin: left;
    animation: scaleIn 0.5s ease forwards;
    animation-delay: 0.6s;
  }

  .hero-desc {
    opacity: 0;
    animation: fadeUp 0.7s ease forwards;
    animation-delay: 0.75s;
  }

  @media (max-width: 900px) {
    .signal-grid {
      grid-template-columns: 1fr;
    }

    .signal-left {
      position: static;
      height: auto;
    }
  }
</style>
