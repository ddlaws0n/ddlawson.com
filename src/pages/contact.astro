---
import Button from '@/components/Button.astro';
import Container from '@/components/Container.astro';
import PageLayout from '@/layouts/PageLayout.astro';
import { SITE } from '@/site.config';
import { Icon } from 'astro-icon/components';
import { actions } from 'astro:actions';

const meta = {
  title: 'Contact',
  description: SITE.description,
  canonical: SITE.origin + '/contact',
};

const result = Astro.getActionResult(actions.submitContactForm);
const isSuccess = !!result && !result.error;
const isError = !!result && !!result.error;

let fieldErrors: Record<string, string[] | undefined> = {};

if (result?.error && 'fields' in result.error && result.error.fields) {
  fieldErrors = result.error.fields as Record<string, string[] | undefined>;
}

const generalErrorMessage = result?.error?.message;

let statusMessage: string | null = null;
if (isSuccess) {
  statusMessage = "Your message has been sent successfully! I'll get back to you soon.";
} else if (generalErrorMessage) {
  statusMessage = generalErrorMessage;
} else if (isError && Object.keys(fieldErrors).length > 0) {
  statusMessage = 'Please correct the errors highlighted below.';
}
---

<PageLayout {meta}>
  <Container
    title="Let's Connect"
    subtitle="I'd love to hear from you!"
    icon="tabler:mail">
    <div class="mx-auto max-w-3xl">
      <div
        class="relative rounded-2xl bg-white p-8 py-14 drop-shadow-2xl drop-shadow-sky-300/50 backdrop-blur-sm dark:bg-slate-800 dark:drop-shadow-md dark:drop-shadow-sky-800/50">
        <!-- Subtle pattern overlay -->
        <div
          class="absolute inset-0 -z-10 rounded-2xl opacity-5"
          style="background-image: url('data:image/svg+xml,%3Csvg width%3D%2260%22 height%3D%2260%22 viewBox%3D%220 0 60 60%22 xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cg fill%3D%22none%22 fill-rule%3D%22evenodd%22%3E%3Cg fill%3D%22%239C92AC%22 fill-opacity%3D%220.4%22%3E%3Cpath d%3D%22M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z%22%2F%3E%3C%2Fg%3E%3C%2Fg%3E%3C%2Fsvg%3E');">
        </div>

        <p class="mb-8 text-center text-slate-600 dark:text-slate-300">
          Have a question, feedback, or just want to say hello? Fill out the form below and I'll get back to you!
        </p>

        <form
          id="contact-form"
          method="POST"
          action="/contact?_action=submitContactForm"
          class="space-y-6"
          autocomplete="off">
          {/* Display Success/Error Messages */}
          {
            statusMessage && (
              <div
                class:list={[
                  'mt-4 text-center text-sm font-medium',
                  { 'text-green-600 dark:text-green-400': isSuccess },
                  { 'text-red-600 dark:text-red-400': isError },
                  { 'text-sky-600 dark:text-sky-400': !isSuccess && !isError },
                ]}>
                {statusMessage}
              </div>
            )
          }

          <div class="space-y-4">
            <div class="flex flex-col max-md:space-y-6 md:grid md:grid-cols-2 md:gap-4">
              <div>
                <label
                  for="name"
                  class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">
                  Name
                </label>
                <div class="relative">
                  <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                    <Icon
                      name="tabler:user"
                      class="size-5 text-slate-400"
                    />
                  </div>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    class:list={[
                      'block w-full rounded-md border bg-white px-10 py-3 text-slate-900 shadow-sm ring-0 placeholder:text-slate-400 focus:border-sky-500 focus:ring-1 focus:ring-sky-500 focus:outline-none dark:bg-slate-800 dark:text-white dark:placeholder:text-slate-500 dark:focus:border-sky-400 dark:focus:ring-sky-400',
                      fieldErrors.name
                        ? 'border-red-500 dark:border-red-400'
                        : 'border-slate-300 dark:border-slate-600',
                    ]}
                    placeholder="Your name"
                    required
                    transition:persist
                  />
                </div>
                {
                  fieldErrors.name && (
                    <p class="mt-1 text-sm text-red-600 dark:text-red-400">{fieldErrors.name.join(', ')}</p>
                  )
                }
              </div>

              <div>
                <label
                  for="email"
                  class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">
                  Email
                </label>
                <div class="relative">
                  <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                    <Icon
                      name="tabler:mail"
                      class="size-5 text-slate-400"
                    />
                  </div>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    class:list={[
                      'block w-full rounded-md border bg-white px-10 py-3 text-slate-900 shadow-sm ring-0 placeholder:text-slate-400 focus:border-sky-500 focus:ring-1 focus:ring-sky-500 focus:outline-none dark:bg-slate-800 dark:text-white dark:placeholder:text-slate-500 dark:focus:border-sky-400 dark:focus:ring-sky-400',
                      // Apply error border if 'email' field error exists
                      fieldErrors.email
                        ? 'border-red-500 dark:border-red-400'
                        : 'border-slate-300 dark:border-slate-600',
                    ]}
                    placeholder="you@example.com"
                    required
                    transition:persist
                  />
                </div>
                {
                  fieldErrors.email && (
                    <p class="mt-1 text-sm text-red-600 dark:text-red-400">{fieldErrors.email.join(', ')}</p>
                  )
                }
              </div>
            </div>

            <div>
              <label
                for="message"
                class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">
                Message
              </label>
              <div class="relative">
                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-start pt-3 pl-3">
                  <Icon
                    name="tabler:message"
                    class="my-1 size-5 text-slate-400"
                  />
                </div>
                <textarea
                  id="message"
                  name="message"
                  rows="2"
                  class:list={[
                    'block max-h-48 w-full resize-y rounded-md border bg-white px-10 py-3 text-slate-900 shadow-sm ring-0 placeholder:text-slate-400 focus:border-sky-500 focus:ring-1 focus:ring-sky-500 focus:outline-none dark:bg-slate-800 dark:text-white dark:placeholder:text-slate-500 dark:focus:border-sky-400 dark:focus:ring-sky-400',
                    fieldErrors.message
                      ? 'border-red-500 dark:border-red-400'
                      : 'border-slate-300 dark:border-slate-600',
                  ]}
                  placeholder="Type your message here..."
                  required
                  transition:persist
                ></textarea>
              </div>
              {
                fieldErrors.message && (
                  <p class="mt-1 text-sm text-red-600 dark:text-red-400">{fieldErrors.message.join(', ')}</p>
                )
              }
            </div>

            <div class="mb-6">
              <div
                id="turnstile-widget"
                class="my-2"
                data-sitekey={import.meta.env.PUBLIC_CAPTCHA_SITE_KEY}
                transition:persist="turnstile-widget">
              </div>
              <input
                type="hidden"
                name="captchaToken"
                id="captchaToken"
                transition:persist
              />
            </div>
            {/* Turnstile Widget Loader Script */}
            <script is:inline>
              // Cloudflare Turnstile widget loader
              // Use astro:page-load for View Transitions compatibility
              document.addEventListener('astro:page-load', () => {
                // Check if the Turnstile API script needs to be loaded
                if (!window.turnstile) {
                  // Avoid adding duplicate scripts if already loading/loaded
                  if (!document.querySelector('script[src="https://challenges.cloudflare.com/turnstile/v0/api.js"]')) {
                    const script = document.createElement('script');
                    script.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
                    script.async = true;
                    script.defer = true;
                    // Append to head to avoid potential body manipulation issues during transitions
                    document.head.appendChild(script);
                    // Wait for the script to load before rendering
                    script.onload = renderTurnstile;
                  }
                  // If script is already loading/loaded but turnstile object not yet ready,
                  // renderTurnstile will be called by its onload or is already called.
                  // If turnstile object *is* ready, the else block handles it.
                } else {
                  // If Turnstile API is already loaded, render the widget directly
                  renderTurnstile();
                }

                function renderTurnstile() {
                  const widgetContainer = document.getElementById('turnstile-widget');
                  // Ensure the container exists and doesn't already have a widget rendered inside
                  if (window.turnstile && widgetContainer && !widgetContainer.querySelector('.cf-turnstile')) {
                    window.turnstile.render('#turnstile-widget', {
                      sitekey: widgetContainer.dataset.sitekey,
                      callback: function (token) {
                        const tokenInput = document.getElementById('captchaToken');
                        if (tokenInput) {
                          tokenInput.value = token;
                        }
                      },
                      'error-callback': function () {
                        console.error('Turnstile error: Failed to render widget.');
                      },
                      'expired-callback': function () {
                        const tokenInput = document.getElementById('captchaToken');
                        if (tokenInput) {
                          tokenInput.value = '';
                        }
                      },
                    });
                  }
                }
              });
            </script>
          </div>

          <div class="flex justify-end">
            <Button
              type="submit"
              variant="outline"
              size="md"
              title="Send Message"
              class="w-full md:w-auto">
              <Icon
                name="tabler:send"
                class="size-4"
              />
            </Button>
          </div>
        </form>
      </div>
    </div>
  </Container>
</PageLayout>

<style>
  .dark .contact-form input,
  .dark .contact-form textarea {
    background-color: rgba(30, 41, 59, 0.5);
    border-color: rgba(51, 65, 85, 0.5);
  }

  @keyframes form-success {
    0%,
    100% {
      transform: translateX(0);
    }
    10%,
    30%,
    50%,
    70%,
    90% {
      transform: translateX(-5px);
    }
    20%,
    40%,
    60%,
    80% {
      transform: translateX(5px);
    }
  }

  .form-success-animation {
    animation: form-success 0.8s ease;
  }
</style>
