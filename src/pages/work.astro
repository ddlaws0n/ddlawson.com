// Define types for our data
interface Role {
  title: string;
  start_date: string;
  end_date: string;
  description: string | null;
}

interface Company {
  company: string;
  location: string;
  roles: Role[];
}

// Function to get logo placeholder (using first letter of company name)
function getLogoPlaceholder(companyName: string): string {
  return companyName.charAt(0).toUpperCase();
}

// Helper function to get primary role
function getPrimaryRole(company: Company): Role {
  return company.roles[0];
}
---

<PageLayout {meta}>
  <Container
    title="Professional Journey"
    subtitle="My career path and professional experiences across various organizations"
  >
    <!-- Timeline Section -->
    <div class="relative mx-auto max-w-4xl">
      <!-- Timeline line -->
      <div class="absolute top-0 left-1/2 h-full w-0.5 -translate-x-1/2 transform bg-sky-200 dark:bg-sky-800"></div>

      {
        workExperience.map((company, index) => {
          const primaryRole = getPrimaryRole(company);
          const isEven = index % 2 === 0;

          return (
            <div class="relative mb-16">
              <div class="absolute top-0 left-1/2 flex h-12 w-12 -translate-x-1/2 transform items-center justify-center rounded-full border-4 border-sky-200 bg-sky-50 text-sky-700 dark:border-sky-800 dark:bg-slate-800 dark:text-sky-300">
                <div class="flex h-8 w-8 items-center justify-center rounded-full bg-sky-600 text-white dark:bg-sky-700">
                  {getLogoPlaceholder(company.company)}
                </div>
              </div>

              <div
                class={`relative mx-4 mt-6 rounded-xl border border-slate-200 bg-white p-6 shadow-md md:mx-0 md:mt-0 md:w-5/12 dark:border-slate-700 dark:bg-slate-800 ${isEven ? 'md:ml-auto' : 'md:mr-auto'}`}
              >
                <div class="mb-2 text-xs font-medium tracking-wider text-sky-600 uppercase dark:text-sky-300">
                  {primaryRole.start_date} - {primaryRole.end_date}
                </div>

                <h2 class="mb-1 text-2xl font-bold text-slate-900 dark:text-white">{company.company}</h2>

                <p class="mb-4 text-sm text-slate-500 dark:text-slate-400">{company.location}</p>

                <div class="space-y-4">
                  {company.roles.map((role, rIndex) => (
                    <div
                      class={`border-l-4 ${rIndex === 0 ? 'border-sky-500' : 'border-slate-300 dark:border-slate-600'} pl-4`}
                    >
                      <h3 class="text-lg font-semibold text-slate-800 dark:text-slate-200">{role.title}</h3>
                      <div class="mb-1 text-xs text-slate-500 dark:text-slate-400">
                        {role.start_date} - {role.end_date}
                      </div>
                      {role.description && (
                        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{role.description}</p>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </Container>
</PageLayout>
