---
import Container from '@/components/Container.astro';
import { SITE } from '@/config';
import PageLayout from '@/layouts/PageLayout.astro';
// Removed unused imports

const meta = {
  title: 'Work Experience',
  description: 'Professional experience and career journey of David D Lawson',
  canonical: SITE.origin + '/work',
};

// Work experience data with summarized descriptions
const workExperience = [
  {
    company: 'Wiz',
    location: 'London Area, United Kingdom',
    summary:
      'Progressed from Senior Customer Success Manager to Manager, Technical Account Management EMEA, advising enterprise clients and leading technical teams to drive cloud security adoption.',
    roles: [
      { title: 'Manager, Technical Account Management EMEA', start_date: 'February 2025', end_date: 'Present' },
      { title: 'Senior Technical Account Manager', start_date: 'April 2024', end_date: 'March 2025' },
      { title: 'Senior Customer Success Manager', start_date: 'November 2023', end_date: 'April 2024' },
    ],
  },
  {
    company: 'Veracode',
    location: 'London, England, United Kingdom',
    summary:
      'Led customer enablement and success teams, doubled community engagement, and drove customer-centric improvements across multiple roles.',
    roles: [
      { title: 'Manager, Customer Experience & Enablement', start_date: 'August 2022', end_date: 'November 2023' },
      { title: 'Team Lead, Customer Success', start_date: 'May 2021', end_date: 'April 2022' },
      { title: 'Senior Security Program Manager', start_date: 'May 2021', end_date: 'May 2021' },
      { title: 'Security Program Manager', start_date: 'March 2020', end_date: 'May 2021' },
    ],
  },
  {
    company: 'Lacework',
    location: 'London, England, United Kingdom',
    summary: 'Drove product adoption and automated internal communications for strategic customers.',
    roles: [{ title: 'Senior Customer Success Manager', start_date: 'April 2022', end_date: 'May 2022' }],
  },
  {
    company: 'Finalsite',
    location: 'London, United Kingdom',
    summary:
      'Managed global digital projects for educational clients, overseeing end-to-end delivery and client engagement.',
    roles: [{ title: 'Digital Project Manager', start_date: 'November 2018', end_date: 'March 2020' }],
  },
  {
    company: 'Nila Expeditions',
    location: 'Turin Area, Italy',
    summary: 'Co-founded and led technical development, building custom travel platforms and IT infrastructure.',
    roles: [
      { title: 'Digital Consultant', start_date: 'September 2018', end_date: 'November 2018' },
      { title: 'Co-founder, Technical Lead', start_date: 'February 2017', end_date: 'September 2018' },
    ],
  },
  // {
  //   company: 'Something Different Wholesale Ltd',
  //   location: 'Swansea, United Kingdom',
  //   summary: 'Implemented project management tools, managed ERP enhancements, and led marketing initiatives.',
  //   roles: [
  //     { title: 'Project Manager', start_date: 'September 2015', end_date: 'February 2017' },
  //     { title: 'Marketing Coordinator / Summer Work Placement', start_date: 'June 2014', end_date: 'August 2014' },
  //   ],
  // },
  // {
  //   company: 'Intimate Places Limited',
  //   location: 'Arusha, Tanzania',
  //   summary: 'Modernized inventory management and supported digital marketing efforts.',
  //   roles: [{ title: 'Marketing Intern / Summer Work Placement', start_date: 'June 2013', end_date: 'August 2013' }],
  // },
  // {
  //   company: 'Upper Zonal Trading',
  //   location: 'Arusha, Tanzania / Dar Es Salaam, Tanzania',
  //   summary: 'Digitized inventory systems and managed IT deployments across Tanzania.',
  //   roles: [{ title: 'IT Consultant / Summer Work Placement', start_date: 'June 2012', end_date: 'August 2012' }],
  // },
];

// Function to get logo placeholder (using first letter of company name)
function getLogoPlaceholder(companyName: string): string {
  return companyName.charAt(0).toUpperCase();
}
---

<PageLayout {meta}>
  <Container
    title="Professional Journey"
    subtitle="My career path and professional experiences across various organizations"
  >
    <!-- Timeline Section -->
    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute top-0 left-1/2 h-full w-0.5 -translate-x-1/2 transform bg-sky-200 dark:bg-sky-800"></div>

      {
        workExperience.map((company, index) => {
          const primaryRole = company.roles[0];
          const isEven = index % 2 === 0;

          return (
            <div class="relative mb-12 sm:mb-16">
              {/* Timeline marker */}
              <div class="absolute top-0 left-1/2 flex h-10 w-10 -translate-x-1/2 transform items-center justify-center rounded-full border-4 border-sky-200 bg-sky-50 text-sky-700 sm:h-12 sm:w-12 dark:border-sky-800 dark:bg-slate-800 dark:text-sky-300">
                <div class="flex h-7 w-7 items-center justify-center rounded-full bg-sky-600 text-white sm:h-8 sm:w-8 dark:bg-sky-700">
                  {getLogoPlaceholder(company.company)}
                </div>
              </div>

              {/* Timeline card */}
              <div
                class={`relative mx-2 mt-6 rounded-xl border border-slate-200 bg-white p-4 shadow-xl shadow-sky-300/30 sm:mx-4 sm:p-6 md:mx-0 md:mt-0 md:w-5/12 dark:border-slate-700 dark:bg-slate-800 dark:shadow-sm dark:shadow-sky-900/90 ${isEven ? 'md:ml-auto' : 'md:mr-auto'}`}
              >
                <div class="mb-1 text-xs font-medium tracking-wider text-sky-600 uppercase dark:text-sky-300">
                  {primaryRole.start_date} - {company.roles[company.roles.length - 1].end_date}
                </div>

                <h2 class="mb-1 text-xl font-bold text-slate-900 sm:text-2xl dark:text-white">{company.company}</h2>

                <p class="mb-2 text-sm text-slate-500 dark:text-slate-400">{company.location}</p>

                <div class="mb-2 flex flex-wrap gap-2">
                  {company.roles.map((role) => (
                    <span class="inline-block rounded bg-sky-100 px-2 py-0.5 text-xs text-sky-700 dark:bg-sky-900 dark:text-sky-200">
                      {role.title}
                    </span>
                  ))}
                </div>

                <p class="text-sm text-slate-700 dark:text-slate-300">{company.summary}</p>
              </div>
            </div>
          );
        })
      }
    </div>
  </Container>
</PageLayout>
