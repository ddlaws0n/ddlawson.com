---
import Button from '@/components/Button.astro';
import Divider from '@/components/Divider.astro';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import SectionEyebrow from '@/components/SectionEyebrow.astro';
import { workExperienceData } from '@/data/workExperience';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/site.config';

const meta = {
  title: 'Work Experience',
  description: 'Professional experience and career journey of David D Lawson',
  canonical: SITE.origin + '/work',
};

function formatRoleDate(dateStr: string): string {
  if (dateStr === 'Present') return 'Present';
  const [year, month] = dateStr.split('-');
  const date = new Date(parseInt(year), parseInt(month) - 1);
  return date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });
}

const linkedInUrl =
  SITE.socialShares.find((s) => s.ariaLabel === 'LinkedIn')?.link ?? 'https://www.linkedin.com/in/ddlawson/';
---

<BaseLayout {meta}>
  <Header />

  <!-- Hero Header -->
  <section class="relative overflow-hidden bg-bg px-12 py-32 max-sm:px-6 max-sm:py-20">
    <!-- Ghost background text -->
    <span
      class="pointer-events-none absolute inset-0 flex items-center justify-center font-display text-[clamp(8rem,22vw,22rem)] leading-none font-extrabold text-text opacity-[0.03] select-none"
      aria-hidden="true">WORK</span
    >
    <div class="relative mx-auto max-w-5xl">
      <SectionEyebrow text="Professional Journey" />
      <div class="reveal mt-4">
        <span
          class="block font-display text-[clamp(4rem,8vw,9rem)] leading-[0.88] font-extrabold text-text opacity-[0.06]"
          >The</span
        >
        <span class="block font-display text-[clamp(4rem,8vw,9rem)] leading-[0.88] font-extrabold text-text"
          >Chronicle</span
        >
      </div>
      <p class="reveal mt-8 max-w-[520px] font-body text-body leading-relaxed font-light text-text-secondary">
        A career built at the intersection of technology and human outcomes.
      </p>
    </div>
  </section>

  <Divider />

  <!-- Company Chapters -->
  {
    workExperienceData.map((company, index) => {
      const chapterNum = String(index + 1).padStart(2, '0');
      const isEven = index % 2 === 1;

      return (
        <section
          class:list={[
            'reveal relative border-l-2 border-accent/20 px-12 py-24 max-sm:px-6 max-sm:py-16',
            isEven ? 'bg-surface' : 'bg-bg',
          ]}
        >
          <div class="relative mx-auto max-w-5xl">
            {/* Ghost chapter number */}
            <span
              class="pointer-events-none absolute -top-4 -left-4 font-display text-[clamp(6rem,14vw,14rem)] leading-none font-extrabold text-text opacity-[0.03] select-none"
              aria-hidden="true"
            >
              {chapterNum}
            </span>

            {/* Company header */}
            <div class="relative mb-10 flex flex-wrap items-center gap-4">
              {company.logoUrl && (
                <img
                  src={company.logoUrl}
                  alt={`${company.company} logo`}
                  class="h-8 w-auto object-contain opacity-80"
                  loading="lazy"
                />
              )}
              <div>
                <h2 class="font-display text-heading font-semibold text-text">{company.company}</h2>
                <p class="text-caption text-text-muted">{company.location}</p>
              </div>
            </div>

            {/* Roles list */}
            <div class="flex flex-col gap-6">
              {company.roles.map((role) => (
                <div class="rounded-lg border border-border bg-elevated p-8 max-sm:p-5">
                  <div class="mb-4 flex flex-wrap items-start justify-between gap-2">
                    <h3 class="font-display text-subheading font-semibold text-text">{role.title}</h3>
                    <span class="shrink-0 text-caption text-accent">
                      {formatRoleDate(role.start_date)} — {formatRoleDate(role.end_date)}
                    </span>
                  </div>

                  {role.responsibilities && role.responsibilities.length > 0 && (
                    <ul class="mb-5 flex flex-col gap-1.5">
                      {role.responsibilities.map((item) => (
                        <li class="flex gap-2 text-small text-text-secondary">
                          <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent/60" aria-hidden="true" />
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  )}

                  {role.achievements && role.achievements.length > 0 && (
                    <div>
                      <p class="mb-2 text-caption font-semibold tracking-widest text-text-muted uppercase">
                        Key Achievements
                      </p>
                      <ul class="flex flex-col gap-1.5">
                        {role.achievements.map((item) => (
                          <li class="flex gap-2 text-small text-text-secondary">
                            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true" />
                            <span set:html={item} />
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        </section>
      );
    })
  }

  <!-- CTA Footer -->
  <section class="bg-bg px-12 py-24 max-sm:px-6 max-sm:py-16">
    <div class="reveal mx-auto flex max-w-5xl flex-col items-start gap-6">
      <p class="font-display text-heading font-semibold text-text">Want the full picture?</p>
      <Button
        title="View LinkedIn Profile"
        link={linkedInUrl}
        variant="primary"
        size="lg"
        icon="tabler:brand-linkedin"
        target="_blank"
        rel="noopener noreferrer"
        umami="linkedin-connect-work"
      />
    </div>
  </section>

  <Footer />

  <script src="../scripts/reveal.ts"></script>
</BaseLayout>
