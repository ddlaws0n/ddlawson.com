---
import { Image } from "astro:assets";
import heroPhoto from "@/assets/img/david-lawson.png";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
    meta={{
        title: "David D. Lawson — Meridian",
        description:
            "Building bridges between technology and the humans who need it.",
        noindex: true,
        nofollow: true,
    }}
>
    <style>
        @import url("https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Outfit:wght@200;300;400;500;600&display=swap");

        :root {
            --m-bg: #0b090e;
            --m-surface: #110f17;
            --m-surface-hover: #181521;
            --m-elevated: #1e1a28;
            --m-blue: #4a9e9e;
            --m-blue-bright: #6bcece;
            --m-blue-muted: #3a7d7d;
            --m-blue-ghost: rgba(74, 158, 158, 0.04);
            --m-blue-ring: rgba(74, 158, 158, 0.12);
            --m-blue-glow: rgba(74, 158, 158, 0.06);
            --m-warm: #c4956a;
            --m-text: #eae8ef;
            --m-text-secondary: #a19baa;
            --m-text-muted: #5a5462;
            --m-border: rgba(255, 255, 255, 0.05);
            --m-border-hover: rgba(255, 255, 255, 0.1);
            --m-display: "Bricolage Grotesque", system-ui, sans-serif;
            --m-body: "Outfit", system-ui, sans-serif;
            --m-content: 940px;
            --m-gutter: clamp(1.25rem, 4vw, 3rem);
        }

        body {
            background-color: var(--m-bg) !important;
            color: var(--m-text) !important;
        }

        body.dark {
            background-color: var(--m-bg) !important;
            color: var(--m-text) !important;
        }

        .meridian-wrap {
            font-family: var(--m-body);
            background: var(--m-bg);
            color: var(--m-text);
            min-height: 100vh;
            position: relative;
            overflow-x: hidden;
        }

        /* ——— NOISE TEXTURE ——— */
        .m-noise {
            position: fixed;
            inset: 0;
            z-index: 9999;
            pointer-events: none;
            opacity: 0.028;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
            background-repeat: repeat;
            background-size: 180px;
            mix-blend-mode: overlay;
        }

        /* ——— NAV ——— */
        .m-nav-bar {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(11, 9, 14, 0.82);
            backdrop-filter: blur(16px) saturate(1.2);
            -webkit-backdrop-filter: blur(16px) saturate(1.2);
            border-bottom: 1px solid var(--m-border);
        }

        .m-nav {
            max-width: var(--m-content);
            margin: 0 auto;
            padding: 1rem var(--m-gutter);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .m-nav-left {
            display: flex;
            align-items: center;
            gap: 1.25rem;
        }

        .m-nav-monogram {
            font-family: var(--m-display);
            font-size: 1.15rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            color: var(--m-text);
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .m-nav-monogram:hover {
            color: var(--m-blue);
        }

        .m-nav-status {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            font-size: 0.58rem;
            font-weight: 300;
            color: var(--m-text-muted);
            letter-spacing: 0.06em;
        }

        .m-nav-dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: var(--m-blue);
            box-shadow: 0 0 6px rgba(74, 158, 158, 0.4);
            animation: m-pulse 3s ease-in-out infinite;
        }

        .m-nav-links {
            display: flex;
            gap: 2rem;
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .m-nav-links a {
            font-family: var(--m-body);
            font-size: 0.75rem;
            font-weight: 400;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--m-text-muted);
            text-decoration: none;
            transition: color 0.25s ease;
            position: relative;
        }

        .m-nav-links a::after {
            content: "";
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 0;
            height: 1px;
            background: var(--m-blue);
            transition: width 0.3s ease;
        }

        .m-nav-links a:hover {
            color: var(--m-text);
        }

        .m-nav-links a:hover::after {
            width: 100%;
        }

        /* ——— CONTENT ——— */
        .m-content {
            max-width: var(--m-content);
            margin: 0 auto;
            padding: 0 var(--m-gutter);
        }

        /* ——— HERO ——— */
        .m-hero {
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 4rem;
            align-items: end;
            padding: 5rem 0 4.5rem;
            min-height: 58vh;
            position: relative;
        }

        .m-hero::before {
            content: "";
            position: absolute;
            top: -80px;
            right: -120px;
            width: 600px;
            height: 600px;
            background: radial-gradient(
                ellipse,
                rgba(74, 158, 158, 0.04) 0%,
                transparent 65%
            );
            pointer-events: none;
        }

        .m-hero-text {
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            opacity: 0;
            animation: m-fadeUp 0.8s cubic-bezier(0.23, 1, 0.32, 1) forwards;
        }

        .m-hero-eyebrow {
            font-family: var(--m-display);
            font-size: 0.58rem;
            font-weight: 600;
            letter-spacing: 0.24em;
            text-transform: uppercase;
            color: var(--m-blue-muted);
            margin-bottom: 1.75rem;
            opacity: 0;
            animation: m-slideIn 0.6s cubic-bezier(0.23, 1, 0.32, 1) forwards
                0.2s;
        }

        .m-hero-name {
            font-family: var(--m-display);
            font-size: clamp(3.2rem, 6.5vw, 5.8rem);
            font-weight: 800;
            line-height: 0.92;
            letter-spacing: -0.03em;
            color: var(--m-text);
            margin: 0 0 1.75rem;
        }

        .m-hero-name .thin {
            font-weight: 300;
            color: var(--m-text-secondary);
        }

        .m-hero-rule {
            width: 64px;
            height: 2px;
            background: linear-gradient(90deg, var(--m-blue), transparent);
            margin-bottom: 1.75rem;
            transform: scaleX(0);
            transform-origin: left;
            animation: m-scaleIn 0.6s cubic-bezier(0.23, 1, 0.32, 1) forwards
                0.5s;
        }

        .m-hero-desc {
            font-family: var(--m-body);
            font-size: 1.05rem;
            font-weight: 300;
            line-height: 1.75;
            color: var(--m-text-secondary);
            max-width: 36ch;
            margin: 0;
            opacity: 0;
            animation: m-fadeUp 0.7s cubic-bezier(0.23, 1, 0.32, 1) forwards
                0.6s;
        }

        .m-hero-social {
            display: flex;
            gap: 1.5rem;
            margin-top: 2.25rem;
            padding: 0;
            list-style: none;
            opacity: 0;
            animation: m-fadeUp 0.6s cubic-bezier(0.23, 1, 0.32, 1) forwards
                0.8s;
        }

        .m-hero-social a {
            font-size: 0.72rem;
            font-weight: 400;
            color: var(--m-text-muted);
            text-decoration: none;
            letter-spacing: 0.04em;
            transition:
                color 0.25s ease,
                transform 0.25s ease;
            display: inline-block;
        }

        .m-hero-social a:hover {
            color: var(--m-blue);
            transform: translateY(-1px);
        }

        .m-hero-photo-wrap {
            position: relative;
            opacity: 0;
            animation: m-revealPhoto 0.9s cubic-bezier(0.23, 1, 0.32, 1)
                forwards 0.3s;
        }

        .m-hero-photo {
            position: relative;
            overflow: hidden;
            border-radius: 6px;
            aspect-ratio: 3 / 4;
            box-shadow:
                0 8px 40px rgba(0, 0, 0, 0.4),
                0 0 0 1px var(--m-border);
        }

        .m-hero-photo :global(img) {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: top center;
            filter: saturate(0.9) contrast(1.02);
        }

        .m-hero-photo-fade {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 40%;
            background: linear-gradient(to top, var(--m-bg), transparent);
            pointer-events: none;
        }

        .m-hero-photo-fade-left {
            position: absolute;
            top: 0;
            left: 0;
            bottom: 0;
            width: 25%;
            background: linear-gradient(
                to right,
                rgba(11, 9, 14, 0.5),
                transparent
            );
            pointer-events: none;
        }

        .m-hero-photo-accent {
            position: absolute;
            bottom: -1px;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--m-blue), transparent 70%);
        }

        .m-hero-photo-glow {
            position: absolute;
            bottom: -20%;
            left: 5%;
            width: 90%;
            height: 50%;
            background: radial-gradient(
                ellipse,
                rgba(74, 158, 158, 0.06) 0%,
                transparent 65%
            );
            pointer-events: none;
        }

        /* ——— INTRO ——— */
        .m-intro {
            padding: 3.5rem 0 4rem;
            max-width: 520px;
            opacity: 0;
            animation: m-fadeUp 0.7s cubic-bezier(0.23, 1, 0.32, 1) forwards
                0.9s;
        }

        .m-intro p {
            font-family: var(--m-body);
            font-size: 1rem;
            font-weight: 300;
            line-height: 1.85;
            color: var(--m-text-secondary);
            margin: 0;
        }

        .m-intro strong {
            font-weight: 500;
            color: var(--m-text);
        }

        /* ——— DIVIDER ——— */
        .m-divider {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem 0;
        }

        .m-divider::before {
            content: "";
            width: 28px;
            height: 1px;
            background: var(--m-blue-muted);
            opacity: 0.5;
        }

        /* ——— SECTION ——— */
        .m-section {
            padding: 5rem 0;
        }

        .m-section-alt {
            background: var(--m-surface);
            margin: 0 calc(-1 * var(--m-gutter));
            padding: 4.5rem var(--m-gutter);
            position: relative;
        }

        .m-section-alt::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(
                90deg,
                transparent,
                var(--m-border-hover),
                transparent
            );
        }

        /* ——— SECTION LABEL ——— */
        .m-label {
            display: flex;
            align-items: center;
            gap: 1.25rem;
            margin-bottom: 2.5rem;
        }

        .m-label-text {
            font-family: var(--m-display);
            font-size: 0.6rem;
            font-weight: 600;
            letter-spacing: 0.24em;
            text-transform: uppercase;
            color: var(--m-text-muted);
            white-space: nowrap;
        }

        .m-label-line {
            flex: 1;
            height: 1px;
            background: linear-gradient(
                90deg,
                var(--m-border-hover),
                transparent 80%
            );
        }

        /* ——— BELIEFS ——— */
        .m-beliefs-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1px;
            background: var(--m-border);
        }

        .m-belief {
            background: var(--m-bg);
            padding: 2.75rem;
            position: relative;
            overflow: hidden;
            transition: background 0.4s ease;
        }

        .m-belief::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 2px;
            height: 0;
            background: var(--m-blue);
            transition: height 0.4s ease;
        }

        .m-belief:hover {
            background: var(--m-surface);
        }

        .m-belief:hover::after {
            height: 100%;
        }

        .m-belief:hover .m-belief-body {
            color: var(--m-text-secondary);
        }

        .m-belief-num {
            font-family: var(--m-display);
            font-size: 7rem;
            font-weight: 200;
            line-height: 0.75;
            color: var(--m-text);
            opacity: 0.02;
            position: absolute;
            top: -0.5rem;
            right: 0.75rem;
            pointer-events: none;
            transition: opacity 0.4s ease;
        }

        .m-belief:hover .m-belief-num {
            opacity: 0.04;
        }

        .m-belief-title {
            font-family: var(--m-display);
            font-size: 1.15rem;
            font-weight: 600;
            line-height: 1.35;
            color: var(--m-text);
            margin-bottom: 0.85rem;
            position: relative;
        }

        .m-belief-title .accent {
            color: var(--m-blue);
        }

        .m-belief-body {
            font-family: var(--m-body);
            font-size: 0.85rem;
            font-weight: 300;
            line-height: 1.75;
            color: var(--m-text-muted);
            position: relative;
            transition: color 0.4s ease;
        }

        /* ——— PROJECTS ——— */
        .m-projects-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.25rem;
        }

        .m-project {
            background: var(--m-surface);
            padding: 2.25rem 2.5rem;
            border-radius: 4px;
            border: 1px solid var(--m-border);
            transition: all 0.35s ease;
            text-decoration: none;
            color: inherit;
            display: block;
            position: relative;
            overflow: hidden;
        }

        .m-project::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(
                90deg,
                transparent,
                var(--m-blue),
                transparent
            );
            opacity: 0;
            transition: opacity 0.35s ease;
        }

        .m-project:hover {
            background: var(--m-elevated);
            border-color: var(--m-border-hover);
            transform: translateY(-2px);
            box-shadow:
                0 8px 32px rgba(0, 0, 0, 0.2),
                0 0 0 1px var(--m-border-hover);
        }

        .m-project:hover::before {
            opacity: 1;
        }

        .m-project-tag {
            font-family: var(--m-display);
            font-size: 0.52rem;
            font-weight: 600;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--m-text-muted);
            margin-bottom: 0.85rem;
            transition: color 0.35s ease;
        }

        .m-project:hover .m-project-tag {
            color: var(--m-blue);
        }

        .m-project-title {
            font-family: var(--m-display);
            font-size: 1.12rem;
            font-weight: 600;
            line-height: 1.3;
            color: var(--m-text);
            margin: 0 0 0.65rem;
        }

        .m-project-desc {
            font-family: var(--m-body);
            font-size: 0.84rem;
            font-weight: 300;
            line-height: 1.7;
            color: var(--m-text-secondary);
        }

        .m-project-arrow {
            display: inline-block;
            font-size: 0.9rem;
            color: var(--m-text-muted);
            margin-top: 1.25rem;
            transition:
                transform 0.3s cubic-bezier(0.23, 1, 0.32, 1),
                color 0.3s ease;
        }

        .m-project:hover .m-project-arrow {
            transform: translateX(6px);
            color: var(--m-blue);
        }

        /* ——— PULL QUOTE ——— */
        .m-quote {
            padding: 5.5rem 0;
            text-align: center;
            position: relative;
        }

        .m-quote-mark {
            font-family: var(--m-display);
            font-size: 8rem;
            font-weight: 800;
            line-height: 0;
            color: var(--m-blue);
            opacity: 0.06;
            position: absolute;
            top: 3.5rem;
            left: 50%;
            transform: translateX(-50%);
            pointer-events: none;
            user-select: none;
        }

        .m-quote-text {
            font-family: var(--m-display);
            font-size: clamp(1.35rem, 2.6vw, 2.1rem);
            font-weight: 500;
            line-height: 1.5;
            color: var(--m-text);
            max-width: 32ch;
            margin: 0 auto 1.5rem;
            position: relative;
        }

        .m-quote-text em {
            font-style: normal;
            color: var(--m-blue-bright);
        }

        .m-quote-rule {
            width: 32px;
            height: 1px;
            background: var(--m-blue-muted);
            margin: 0 auto 1.25rem;
        }

        .m-quote-attr {
            font-family: var(--m-body);
            font-size: 0.65rem;
            font-weight: 400;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--m-text-muted);
        }

        /* ——— WRITING ——— */
        .m-posts {
            display: flex;
            flex-direction: column;
        }

        .m-post {
            display: grid;
            grid-template-columns: 88px 1fr auto;
            gap: 1.75rem;
            align-items: center;
            padding: 1.25rem 1.25rem;
            border-bottom: 1px solid var(--m-border);
            text-decoration: none;
            color: inherit;
            transition: all 0.25s ease;
            margin: 0 -1.25rem;
            border-radius: 3px;
        }

        .m-post:first-child {
            border-top: 1px solid var(--m-border);
        }

        .m-post:hover {
            background: var(--m-blue-ghost);
            border-bottom-color: transparent;
        }

        .m-post:hover + .m-post {
            border-top-color: transparent;
        }

        .m-post:hover .m-post-title {
            color: var(--m-blue-bright);
        }

        .m-post:hover .m-post-date {
            color: var(--m-blue);
        }

        .m-post-date {
            font-family: var(--m-display);
            font-size: 0.68rem;
            font-weight: 400;
            color: var(--m-text-muted);
            letter-spacing: 0.02em;
            transition: color 0.25s ease;
        }

        .m-post-title {
            font-family: var(--m-body);
            font-size: 0.95rem;
            font-weight: 400;
            color: var(--m-text);
            transition: color 0.25s ease;
        }

        .m-post-tag {
            font-family: var(--m-display);
            font-size: 0.52rem;
            font-weight: 500;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--m-text-muted);
            border: 1px solid var(--m-border);
            padding: 0.2rem 0.55rem;
            border-radius: 2px;
            transition:
                border-color 0.25s ease,
                color 0.25s ease;
        }

        .m-post:hover .m-post-tag {
            border-color: var(--m-blue-ring);
            color: var(--m-blue-muted);
        }

        .m-view-all {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            margin-top: 1.75rem;
            font-size: 0.8rem;
            font-weight: 400;
            color: var(--m-blue);
            text-decoration: none;
            transition:
                gap 0.3s ease,
                color 0.3s ease;
        }

        .m-view-all:hover {
            gap: 0.75rem;
            color: var(--m-blue-bright);
        }

        /* ——— FOOTER ——— */
        .m-footer-wrap {
            border-top: 1px solid var(--m-border);
            margin-top: 2rem;
            background: var(--m-bg);
        }

        .m-footer {
            max-width: var(--m-content);
            margin: 0 auto;
            padding: 2rem var(--m-gutter);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .m-footer-copy {
            font-size: 0.68rem;
            font-weight: 300;
            color: var(--m-text-muted);
        }

        .m-footer-links {
            display: flex;
            gap: 1.75rem;
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .m-footer-links a {
            font-size: 0.68rem;
            font-weight: 400;
            color: var(--m-text-muted);
            text-decoration: none;
            transition: color 0.25s ease;
        }

        .m-footer-links a:hover {
            color: var(--m-blue);
        }

        /* ——— SCROLL REVEAL ——— */
        .m-reveal {
            opacity: 0;
            transform: translateY(20px);
            transition:
                opacity 0.7s cubic-bezier(0.23, 1, 0.32, 1),
                transform 0.7s cubic-bezier(0.23, 1, 0.32, 1);
        }

        .m-reveal.is-visible {
            opacity: 1;
            transform: translateY(0);
        }

        .m-reveal-delay-1 {
            transition-delay: 0.1s;
        }
        .m-reveal-delay-2 {
            transition-delay: 0.2s;
        }
        .m-reveal-delay-3 {
            transition-delay: 0.3s;
        }

        /* ——— ANIMATIONS ——— */
        @keyframes m-fadeUp {
            from {
                opacity: 0;
                transform: translateY(18px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes m-slideIn {
            from {
                opacity: 0;
                transform: translateX(-12px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @keyframes m-scaleIn {
            from {
                transform: scaleX(0);
                opacity: 0;
            }
            to {
                transform: scaleX(1);
                opacity: 1;
            }
        }

        @keyframes m-revealPhoto {
            from {
                opacity: 0;
                transform: translateY(24px) scale(0.98);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        @keyframes m-pulse {
            0%,
            100% {
                opacity: 1;
            }
            50% {
                opacity: 0.25;
            }
        }

        /* ——— FOCUS ——— */
        a:focus-visible {
            outline: 2px solid var(--m-blue);
            outline-offset: 3px;
            border-radius: 2px;
        }

        /* ——— RESPONSIVE ——— */
        @media (max-width: 900px) {
            .m-hero {
