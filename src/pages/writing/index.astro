---
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import PostListItem from '@/components/PostListItem.astro';
import SectionEyebrow from '@/components/SectionEyebrow.astro';
import TagPill from '@/components/TagPill.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/site.config';
import { getFormattedDate, getReadingTime } from '@/utils';
import { getCollection, type CollectionEntry } from 'astro:content';

const unsortedPosts = await getCollection('writing', ({ data }) => {
  return !data.draft && data.publishDate < new Date();
});

const blogPosts = unsortedPosts.sort(
  (a: CollectionEntry<'writing'>, b: CollectionEntry<'writing'>) =>
    b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const featuredPost = blogPosts[0];
const remainingPosts = blogPosts.slice(1);

const allTags = Array.from(new Set(blogPosts.flatMap((p) => p.data.tags ?? [])));

const meta = {
  title: 'Writing — The Archive',
  description: 'Thoughts on technology, customer success, AI, and building things.',
  canonical: SITE.origin + '/writing',
};
---

<BaseLayout {meta}>
  <Header />

  <!-- Hero Header -->
  <section class="relative overflow-hidden bg-bg px-12 py-32 max-sm:px-6 max-sm:py-16">
    <span
      class="pointer-events-none absolute inset-0 flex items-center justify-center font-display text-ghost font-extrabold text-text select-none"
      style="opacity:0.03;line-height:1;"
      aria-hidden="true"
    >
      WRITING
    </span>
    <div class="relative z-10 max-w-4xl">
      <SectionEyebrow text="The Archive" />
      <h1 class="mb-4 font-display text-display font-extrabold text-text">Writing</h1>
      <p class="max-w-[55ch] font-body text-body text-text-secondary">
        Thoughts on technology, customer success, AI, and building things.
      </p>
    </div>
  </section>

  <!-- Featured Post -->
  {
    featuredPost && (
      <section class="bg-surface px-12 py-16 max-sm:px-6 max-sm:py-10">
        <div class="max-w-4xl">
          <p class="mb-6 font-display text-caption font-semibold tracking-[0.22em] text-text-muted uppercase">Latest</p>
          <a href={`/writing/${featuredPost.id}`} class="reveal group block border-l-2 border-accent pl-8 max-sm:pl-5">
            <h2
              class="mb-3 font-display leading-tight font-semibold text-text"
              style="font-size: clamp(1.5rem, 3vw, 2.2rem);"
            >
              {featuredPost.data.title}
            </h2>
            <p class="mb-4 font-body text-caption text-text-muted">
              {getFormattedDate(featuredPost.data.publishDate)}
              {featuredPost.body && <span> · {getReadingTime(featuredPost.body)} min read</span>}
            </p>
            {featuredPost.data.description && (
              <p class="mb-5 max-w-[60ch] font-body text-body text-text-secondary">{featuredPost.data.description}</p>
            )}
            {(featuredPost.data.tags?.length ?? 0) > 0 && (
              <div class="mb-6 flex flex-wrap gap-2">
                {featuredPost.data.tags!.map((tag) => (
                  <TagPill tag={tag} />
                ))}
              </div>
            )}
            <span class="font-body text-small text-accent group-hover:underline">Read Article →</span>
          </a>
        </div>
      </section>
    )
  }

  <!-- Tag Filter -->
  <section class="border-b border-border bg-bg px-12 py-8 max-sm:px-6">
    <div class="flex max-w-4xl flex-wrap gap-2" id="tag-filter">
      <button
        data-tag="all"
        class="tag-pill active-pill rounded-sm px-3 py-1 font-display text-[0.52rem] font-bold tracking-[0.15em] whitespace-nowrap uppercase transition-colors"
      >
        All
      </button>
      {
        allTags.map((tag) => (
          <button
            data-tag={tag}
            class="tag-pill rounded-sm border border-border px-3 py-1 font-display text-[0.52rem] font-bold tracking-[0.15em] whitespace-nowrap text-text-muted uppercase transition-colors hover:text-text"
          >
            {tag}
          </button>
        ))
      }
    </div>
  </section>

  <!-- Post List -->
  <section class="bg-bg px-12 pb-24 max-sm:px-6 max-sm:pb-16">
    <div class="max-w-4xl">
      <div class="post-list">
        {
          remainingPosts.map((post) => {
            const tag = post.data.tags?.[0] ?? '';
            return (
              <div data-tag={tag}>
                <PostListItem
                  date={getFormattedDate(post.data.publishDate)}
                  title={post.data.title}
                  tag={tag || undefined}
                  href={`/writing/${post.id}`}
                />
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script src="../../scripts/reveal.ts"></script>

<script>
  function initTagFilter() {
    const filterEl = document.getElementById('tag-filter');
    if (!filterEl) return;

    const buttons = filterEl.querySelectorAll<HTMLButtonElement>('.tag-pill');
    const postList = document.querySelector<HTMLElement>('.post-list');
    if (!postList) return;

    const items = postList.querySelectorAll<HTMLElement>(':scope > div');

    function setActive(btn: HTMLButtonElement) {
      buttons.forEach((b) => {
        b.classList.remove('active-pill', 'bg-accent', 'text-bg');
        b.classList.add('border', 'border-border', 'text-text-muted');
      });
      btn.classList.add('active-pill', 'bg-accent', 'text-bg');
      btn.classList.remove('border', 'border-border', 'text-text-muted');
    }

    function filterPosts(tag: string) {
      items.forEach((item) => {
        const itemTag = item.getAttribute('data-tag') ?? '';
        if (tag === 'all' || itemTag === tag) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const tag = btn.getAttribute('data-tag') ?? 'all';
        setActive(btn);
        filterPosts(tag);
      });
    });
  }

  document.addEventListener('astro:page-load', initTagFilter);
  initTagFilter();
</script>

<style>
  .active-pill {
    background-color: var(--color-accent);
    color: var(--color-bg);
    border-color: transparent;
  }
</style>
