---
import Divider from '@/components/Divider.astro';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import PostListItem from '@/components/PostListItem.astro';
import SectionEyebrow from '@/components/SectionEyebrow.astro';
import TagPill from '@/components/TagPill.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/site.config';
import { getFormattedDate, getReadingTime } from '@/utils';
import { getCollection, type CollectionEntry } from 'astro:content';

const unsortedPosts = await getCollection('writing', ({ data }) => {
  return !data.draft && data.publishDate < new Date();
});

const blogPosts = unsortedPosts.sort(
  (a: CollectionEntry<'writing'>, b: CollectionEntry<'writing'>) =>
    b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const featuredPost = blogPosts[0];
const remainingPosts = blogPosts.slice(1);

const allTags = Array.from(new Set(blogPosts.flatMap((p) => p.data.tags ?? [])));

const meta = {
  title: 'Writing',
  description: 'Thinking out loud about technology, customer success, AI, and building things that matter.',
  canonical: SITE.origin + '/writing',
};
---

<BaseLayout {meta}>
  <Header />
  <main id="main-content">
    <!-- ─── Hero ─────────────────────────────────────────────────────────── -->
    <section class="writing-hero">
      <div class="writing-hero-text">
        <p class="hero-eyebrow font-display text-caption font-semibold tracking-wide text-text-muted uppercase">
          The Archive
        </p>

        <h1
          class="mt-6 font-display text-hero leading-[0.92] font-extrabold text-text"
          style="letter-spacing: var(--tracking-hero);"
        >
          <span class="line line-1 opacity-watermark">Every</span>
          <span class="line line-2">Word</span>
        </h1>

        <div class="hero-rule my-10 h-0.5 w-[100px] bg-accent"></div>

        <p class="hero-desc max-w-[42ch] font-body text-body-lg leading-relaxed font-light text-text-secondary">
          Thinking out loud about technology, customer success, AI, and the things I'm learning along the way.
        </p>
      </div>
    </section>

    <Divider />

    <!-- ─── Featured Post ────────────────────────────────────────────────── -->
    {
      featuredPost && (
        <section
          id="featured"
          class="relative bg-surface py-24 max-sm:py-16"
          style="padding-left: 4.5rem; padding-right: 3rem;"
        >
          <SectionEyebrow text="Latest" sideways />
          <div class="pl-12 max-lg:pl-0">
            <a href={`/writing/${featuredPost.id}`} class="reveal group block">
              <div class="grid grid-cols-[1fr_1.4fr] items-start gap-16 max-lg:grid-cols-1 max-lg:gap-6">
                {/* Left — Meta */}
                <div>
                  <span class="block font-body text-caption tracking-widest text-text-muted uppercase">
                    {getFormattedDate(featuredPost.data.publishDate)}
                    {featuredPost.body && <span> · {getReadingTime(featuredPost.body)} min read</span>}
                  </span>
                  {(featuredPost.data.tags?.length ?? 0) > 0 && (
                    <div class="mt-4 flex flex-wrap gap-2">
                      {featuredPost.data.tags!.map((tag) => (
                        <TagPill tag={tag} />
                      ))}
                    </div>
                  )}
                  <span class="mt-6 inline-block font-body text-small text-accent transition-colors group-hover:text-accent-bright">
                    Read Article →
                  </span>
                </div>

                {/* Right — Title & excerpt */}
                <div class="border-l-2 border-accent/30 pl-8 max-lg:border-l-0 max-lg:pl-0">
                  <h2 class="font-display text-heading leading-snug font-semibold text-text transition-colors group-hover:text-accent">
                    {featuredPost.data.title}
                  </h2>
                  {featuredPost.data.description && (
                    <p class="mt-4 max-w-[55ch] font-body text-body leading-relaxed font-light text-text-secondary">
                      {featuredPost.data.description}
                    </p>
                  )}
                </div>
              </div>
            </a>
          </div>
        </section>
      )
    }

    <Divider />

    <!-- ─── All Posts ────────────────────────────────────────────────────── -->
    <section id="archive" class="relative bg-bg py-24 max-sm:py-16" style="padding-left: 4.5rem; padding-right: 3rem;">
      <SectionEyebrow text="Archive" sideways />
      <div class="pl-12 max-lg:pl-0">
        {/* Tag filter */}
        {
          allTags.length > 0 && (
            <div class="mb-12 flex flex-wrap gap-2" id="tag-filter">
              <button
                data-tag="all"
                class="tag-pill active-pill rounded-sm px-3 py-1 font-display text-caption font-bold tracking-label whitespace-nowrap uppercase transition-colors"
              >
                All
              </button>
              {allTags.map((tag) => (
                <button
                  data-tag={tag}
                  class="tag-pill rounded-sm border border-border px-3 py-1 font-display text-caption font-bold tracking-label whitespace-nowrap text-text-muted uppercase transition-colors hover:text-text"
                >
                  {tag}
                </button>
              ))}
            </div>
          )
        }

        {/* Post list */}
        <div class="post-list">
          {
            remainingPosts.length > 0 ? (
              remainingPosts.map((post) => {
                const tag = post.data.tags?.[0] ?? '';
                return (
                  <div data-tag={tag}>
                    <PostListItem
                      date={getFormattedDate(post.data.publishDate)}
                      title={post.data.title}
                      tag={tag || undefined}
                      href={`/writing/${post.id}`}
                    />
                  </div>
                );
              })
            ) : (
              <p class="font-body text-body font-light text-text-muted">More writing coming soon.</p>
            )
          }
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  function initTagFilter() {
    const filterEl = document.getElementById('tag-filter');
    if (!filterEl) return;

    const buttons = filterEl.querySelectorAll<HTMLButtonElement>('.tag-pill');
    const postList = document.querySelector<HTMLElement>('.post-list');
    if (!postList) return;

    const items = postList.querySelectorAll<HTMLElement>(':scope > div');

    function setActive(btn: HTMLButtonElement) {
      buttons.forEach((b) => {
        b.classList.remove('active-pill', 'bg-accent', 'text-bg');
        b.classList.add('border', 'border-border', 'text-text-muted');
      });
      btn.classList.add('active-pill', 'bg-accent', 'text-bg');
      btn.classList.remove('border', 'border-border', 'text-text-muted');
    }

    function filterPosts(tag: string) {
      items.forEach((item) => {
        const itemTag = item.getAttribute('data-tag') ?? '';
        if (tag === 'all' || itemTag === tag) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const tag = btn.getAttribute('data-tag') ?? 'all';
        setActive(btn);
        filterPosts(tag);
      });
    });
  }

  document.addEventListener('astro:page-load', initTagFilter);
  initTagFilter();
</script>

<style>
  /* ——— Hero layout ——— */
  .writing-hero {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    overflow: hidden;
    padding: 0 3rem 5rem 3rem;
  }

  .writing-hero-text {
    position: relative;
    z-index: 2;
    max-width: 680px;
  }

  /* ——— Hero animations ——— */
  .hero-eyebrow {
    opacity: 0;
    animation: fadeUp 0.6s ease forwards;
    animation-delay: 0.15s;
  }

  .line {
    display: block;
    clip-path: inset(100% 0 0 0);
    animation: clipReveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .line-1 {
    animation-delay: 0.25s;
  }
  .line-2 {
    animation-delay: 0.42s;
  }

  .hero-rule {
    opacity: 0;
    transform: scaleX(0);
    transform-origin: left;
    animation: scaleIn 0.5s ease forwards;
    animation-delay: 0.7s;
  }

  .hero-desc {
    opacity: 0;
    animation: fadeUp 0.7s ease forwards;
    animation-delay: 0.85s;
  }

  /* ——— Tag filter active state ——— */
  .active-pill {
    background-color: var(--color-accent);
    color: var(--color-bg);
    border-color: transparent;
  }

  /* ——— Responsive ——— */
  @media (max-width: 900px) {
    .writing-hero {
      min-height: 70vh;
      padding: 4rem 1.5rem 3rem;
    }
  }

  @media (max-width: 640px) {
    #featured,
    #archive {
      padding-left: 1.5rem !important;
      padding-right: 1.5rem !important;
    }
  }
</style>
