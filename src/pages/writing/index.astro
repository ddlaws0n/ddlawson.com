---
import { getCollection } from "astro:content";
import Footer from "@/components/Footer.astro";
import Nav from "@/components/Nav.astro";
import PostCard from "@/components/PostCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { conf } from "@/site.config.ts";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const dateFmt = conf.blog.dateFormatter;

function formatDate(date: Date): string {
  return dateFmt.format(date);
}
---

<BaseLayout
  meta={{
    title: "Writing",
    description:
      "Thoughts on customer experience, security strategy, product leadership, and building things that work.",
    noindex: true,
    nofollow: true,
  }}
>
  <div
    class="font-body bg-background text-text relative min-h-screen overflow-x-hidden"
  >
    <div class="m-noise"></div>
    <Nav />
    <main id="main-content" class="max-w-content mx-auto px-(--m-gutter)">
      <!-- Page header -->
      <header
        class="animate-fade-up pt-10 pb-8 opacity-0 motion-reduce:opacity-100 sm:pt-12 md:pt-14 lg:pt-16 lg:pb-14"
      >
        <span
          class="font-display text-teal-muted text-label mb-2 block font-semibold tracking-[0.24em] uppercase md:mb-3 lg:mb-5"
        >
          Writing
        </span>
        <h1
          class="font-display text-hero text-text max-w-[14ch] font-extrabold"
        >
          Thoughts & reflections
        </h1>
        <p
          class="font-body text-prose text-text-secondary mt-5 mb-0 max-w-[52ch] font-light lg:mt-8"
        >
          Ideas at the intersection of customer experience, security, product
          leadership, and the messy reality of building things that actually work
          for people.
        </p>
      </header>

      <!-- Post list -->
      <section class="m-section">
        <div class="m-label">
          <span
            class="font-display text-text-muted text-label font-semibold tracking-[0.24em] whitespace-nowrap uppercase"
          >
            {posts.length} {posts.length === 1 ? "Post" : "Posts"}
          </span>
          <div
            class="from-border-hover h-px flex-1 bg-linear-to-r to-transparent/80"
          ></div>
        </div>

        {posts.length === 0 && (
          <p class="text-prose text-text-muted py-16 text-center">No posts yet — check back soon.</p>
        )}

        <div class="flex flex-col">
          {
            posts.map((post, i) => (
              <PostCard post={post} showDescription={true} formatDate={formatDate} index={i} />
            ))
          }
        </div>
      </section>
    </main>
    <Footer />
  </div>
</BaseLayout>
