---
import { SITE } from '@/config';
import PageLayout from '@/layouts/PageLayout.astro';
import { getFormattedDate } from '@/utils/utils';
import { getReadingTime } from '@/utils/readingtime';
import { getCollection } from 'astro:content';

export const prerender = true;

import type { CollectionEntry } from 'astro:content';
import type { MetaSEO } from '@/types.d.ts';

export async function getStaticPaths() {
  const blogEntries = await getCollection('writing');
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// Use Astro's built-in type instead of custom BlogPost type
const { entry } = Astro.props as { entry: CollectionEntry<'writing'> };
const { Content } = await entry.render();

const meta: MetaSEO = {
  title: entry.data.title,
  description: entry.data.description,
  canonical: SITE.origin + `/writing/${entry.slug}`,
  // image: await findImage(post.image),
  // noindex: BLOG?.post?.noindex,
  ogTitle: entry.data.title, // Use ogTitle instead of ogType
};
---

<PageLayout {meta}>
  <div class="">
    <div class="container mx-auto space-y-16 px-4 py-8 lg:px-8 lg:py-16 xl:max-w-7xl">
      <div
        class="mb-12 border-b border-slate-200 pb-8 text-center lg:mb-16 lg:pb-12 lg:text-left dark:border-slate-700">
        <h1 class="text-5xl font-black tracking-tight text-slate-900 md:text-6xl lg:text-7xl dark:text-slate-100">
          {entry.data.title}
        </h1>
        <div
          class="mt-4 flex flex-col items-center justify-center gap-2 text-base font-medium text-slate-600 md:flex-row md:justify-start md:text-lg lg:text-xl dark:text-slate-200">
          <span class="font-semibold">{entry.data.author}</span>
          <span class="hidden md:inline">&middot;</span>
          <time
            datetime={entry.data.publishDate instanceof Date
              ? entry.data.publishDate.toISOString()
              : entry.data.publishDate}
            class="font-semibold">
            {getFormattedDate(entry.data.publishDate)}
          </time>
          <span class="hidden md:inline">&middot;</span>
          <span>{getReadingTime(entry.body)} min read</span>
        </div>
        <p class="mt-2 text-lg text-slate-500 italic dark:text-slate-400">{entry.data.description}</p>
      </div>

      <article
        class="mx-auto prose max-w-3xl text-justify prose-slate md:prose-lg dark:prose-invert prose-headings:underline prose-a:text-sky-800 prose-img:rounded-xl prose-lead:leading-relaxed">
        <Content />
      </article>
    </div>
  </div>
</PageLayout>
