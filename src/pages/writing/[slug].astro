---
import ArticleHeader from '@/components/ArticleHeader.astro';
import Divider from '@/components/Divider.astro';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/site.config';
import { getReadingTime } from '@/utils';
import { getCollection, render } from 'astro:content';
export const prerender = true;

import type { MetaSEO } from '@/types';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const blogEntries = await getCollection('writing');
  return blogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'writing'> };
const { Content } = await render(entry);

const meta: MetaSEO = {
  title: entry.data.title,
  description: entry.data.description,
  canonical: SITE.origin + `/writing/${entry.id}`,
  ogTitle: entry.data.title,
};

const readingTime = `${entry.body ? getReadingTime(entry.body) : '5'} min read`;
---

<BaseLayout {meta}>
  <Header />
  <main>
    <ArticleHeader
      title={entry.data.title}
      date={entry.data.publishDate}
      readingTime={readingTime}
      tags={entry.data.tags}
    />
    <article
      class="prose-anthem mx-auto prose max-w-prose px-12 py-16 prose-invert max-sm:px-6 prose-headings:font-display prose-headings:font-semibold prose-headings:text-text prose-p:leading-[1.85] prose-p:font-light prose-p:text-text-secondary prose-a:text-accent prose-a:underline-offset-2 prose-strong:text-text prose-code:text-accent-bright prose-li:text-text-secondary"
    >
      <Content />
    </article>

    <Divider />

    <!-- Back to archive -->
    <section class="section-padding bg-surface py-16">
      <div class="pl-12 max-lg:pl-0">
        <a
          href="/writing"
          class="magnetic-cta inline-flex items-center gap-2.5 border-b border-border pb-1 font-display text-small font-semibold tracking-tight text-text-secondary no-underline transition-[gap,border-color,color] duration-300 hover:gap-3.5 hover:border-accent hover:text-accent"
        >
          &larr; Back to the Archive
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
