---
import AuthorProfile from '@/assets/images/david-d-lawson-profile.jpg';
import PageLayout from '@/layouts/PageLayout.astro';
import { SITE } from '@/site.config';
import { getFormattedDate, getReadingTime } from '@/utils';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
export const prerender = true;

import type { MetaSEO } from '@/types';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const blogEntries = await getCollection('writing');
  return blogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'writing'> };
const { Content } = await render(entry);

const meta: MetaSEO = {
  title: entry.data.title,
  description: entry.data.description,
  canonical: SITE.origin + `/writing/${entry.id}`,
  ogTitle: entry.data.title,
};
---

<PageLayout {meta}>
  <article class="container mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <span
        class="inline-flex items-center rounded-full bg-gray-200 px-4 py-1.5 text-sm font-medium text-gray-800 dark:bg-gray-700 dark:text-gray-200"
      >
        {entry.data.category || 'Blogging'}
      </span>
    </div>

    <h1
      class="mb-12 text-center text-4xl leading-tight font-black text-gray-900 sm:text-5xl lg:text-6xl dark:text-gray-100"
    >
      {entry.data.title}
    </h1>

    <div class="mb-16 flex items-center justify-center space-x-6 text-gray-600 dark:text-gray-400">
      <div class="flex items-center space-x-3">
        {
          entry.data.author == 'David D Lawson' && (
            <Image
              src={AuthorProfile}
              alt={entry.data.author}
              width={40}
              height={40}
              class="text-foreground bg-muted relative h-10 w-10 overflow-hidden rounded-full border-2 object-cover text-sm"
            />
          )
        }
        <span class="font-medium text-gray-900 dark:text-gray-100">
          {entry.data.author}
        </span>
      </div>

      <div class="flex items-center space-x-2">
        <Icon name="tabler:calendar" class="h-5 w-5" />
        <time
          datetime={entry.data.publishDate instanceof Date
            ? entry.data.publishDate.toISOString()
            : entry.data.publishDate}
        >
          {getFormattedDate(entry.data.publishDate)}
        </time>
      </div>

      <div class="flex items-center space-x-2">
        <Icon name="tabler:clock" class="h-5 w-5" />
        <span>{entry.body ? getReadingTime(entry.body) : '5'} min read</span>
      </div>
    </div>

    <div
      class="prose prose-lg max-w-none prose-gray dark:prose-invert prose-headings:font-bold prose-headings:tracking-tight prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-strong:text-gray-900 dark:prose-strong:text-gray-100 prose-code:rounded prose-code:bg-gray-100 prose-code:px-1 prose-code:py-0.5 prose-code:text-gray-800 dark:prose-code:bg-gray-800 dark:prose-code:text-gray-200 prose-pre:bg-gray-100 dark:prose-pre:bg-gray-800 prose-img:rounded-lg prose-img:shadow-md"
    >
      <Content />
    </div>
  </article>
</PageLayout>
