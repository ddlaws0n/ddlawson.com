---
import { getCollection, render } from "astro:content";
import Footer from "@/components/Footer.astro";
import Nav from "@/components/Nav.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { conf } from "@/site.config.ts";
import { getReadingTime } from "@/utils/reading-time";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const { title, description, date, tag } = post.data;
const dateFmt = conf.blog.dateFormatter;
const formattedDate = dateFmt.format(date);
const readingTime = post.body ? getReadingTime(post.body) : undefined;
const ogImage = new URL(`/og/${post.id}.png`, conf.site.origin).href;
---

<BaseLayout
  meta={{
    title,
    description,
    image: ogImage,
    imageAlt: `${title} — ${conf.site.domain}`,
    ogType: "article",
    publishedTime: date.toISOString(),
    articleAuthor: conf.site.name,
    articleTag: tag,
  }}
>
  <div
    class="font-body bg-background text-text relative min-h-screen overflow-x-hidden"
  >
    <div class="m-noise"></div>
    <Nav />
    <main id="main-content" class="max-w-content mx-auto px-(--m-gutter)">
      <article>
        <!-- Post header -->
        <header
          class="max-w-copy mx-auto animate-fade-up pt-10 pb-8 opacity-0 motion-reduce:opacity-100 sm:pt-12 md:pt-14 lg:pt-20 lg:pb-12"
        >
          <div class="mb-5 flex items-center gap-4 md:mb-7">
            <span
              class="font-display text-detail text-teal-muted border-teal/12 rounded-sm border px-[0.55rem] py-[0.2rem] font-medium tracking-[0.14em] uppercase"
            >
              {tag}
            </span>
            <span
              class="font-display text-text-muted lg:text-caption text-sm font-normal tracking-[0.02em]"
            >
              {formattedDate}
            </span>
            {readingTime && (
              <span class="text-text-muted text-sm font-normal"
                >&middot; {readingTime}</span
              >
            )}
          </div>
          <h1
            class="font-display text-quote text-text font-extrabold leading-tight"
          >
            {title}
          </h1>
          <p
            class="text-prose text-text-secondary mt-4 mb-0 max-w-[52ch] font-normal lg:mt-6"
          >
            {description}
          </p>
        </header>

        <!-- Divider -->
        <div class="max-w-copy mx-auto m-divider mb-8 lg:mb-12"></div>

        <!-- Post body -->
        <div
          class="max-w-copy mx-auto prose prose-invert animate-fade-up-fast opacity-0 motion-reduce:opacity-100"
          style="animation-delay: 120ms"
        >
          <Content />
        </div>

        <!-- Post footer -->
        <footer class="max-w-copy mx-auto mt-12 flex items-center justify-between border-border border-t pt-8 pb-4 lg:mt-16 lg:pt-10">
          <a
            href="/writing"
            class="text-micro text-teal hover:text-teal-bright inline-flex items-center gap-2 font-normal no-underline transition-all duration-300 hover:gap-3"
          >
            <span>&larr;</span>
            <span>Back to all writing</span>
          </a>
          <button
            type="button"
            class="js-copy-link text-micro text-teal hover:text-teal-bright inline-flex items-center gap-1.5 rounded-sm p-2.5 font-normal transition-colors duration-250"
            aria-label="Copy link to clipboard"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
            </svg>
            <span class="js-copy-label">Copy link</span>
          </button>
        </footer>
      </article>
    </main>
    <Footer />
  </div>
</BaseLayout>

<script>
  function initCopyLink() {
    document.querySelectorAll<HTMLButtonElement>(".js-copy-link").forEach((btn) => {
      btn.addEventListener("click", async () => {
        await navigator.clipboard.writeText(window.location.href);
        const slug = window.location.pathname.split("/").pop() ?? "";
        window.umami?.track("copy-link", { slug });
        const label = btn.querySelector(".js-copy-label");
        if (!label) return;
        const original = label.textContent;
        label.textContent = "Copied!";
        setTimeout(() => {
          label.textContent = original;
        }, 2000);
      });
    });
  }
  initCopyLink();
  document.addEventListener("astro:after-swap", initCopyLink);
</script>
