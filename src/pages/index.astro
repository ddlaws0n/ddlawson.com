---
import { SITE } from '@/config';
import PageLayout from '@/layouts/PageLayout.astro';
import Button from '@/components/Button.astro';
import { Image } from 'astro:assets';
import HeroImage from '@/assets/images/david-d-lawson-ai-profile.png';
const meta = {
  title: SITE.title,
  description: SITE.description,
  dontUseTitleTemplate: true,
  canonical: SITE.origin,
};
---

<PageLayout {meta}>
  <section class="overflow-hidden">
    <div class="relative container mx-auto px-4 py-24 lg:px-8 xl:max-w-7xl">
      <div class="grid grid-cols-1 md:grid-cols-2">
        <div class="col-span-1 place-self-center md:order-last">
          <div class="relative mx-auto mb-20 w-56 md:mb-14 lg:w-72">
            <div
              class="bg-opacity-50 absolute inset-0 -m-4 rotate-2 transform rounded-xl bg-sky-200 transition-all duration-500 dark:bg-sky-700">
            </div>
            <div
              class="bg-opacity-50 absolute inset-0 -m-4 -rotate-2 transform rounded-xl bg-sky-300 transition-all duration-500 dark:bg-sky-800">
            </div>
            <div class="relative mx-auto rounded-lg shadow-lg">
              <Image
                src={HeroImage}
                alt="David D Lawson AI Profile Image"
                format="webp"
                width={512}
                height={512}
              />
            </div>
          </div>
        </div>
        <div class="col-span-1">
          <!-- <div class="mb-2 inline-flex rounded-xs bg-slate-200 px-2 py-1 text-sm font-semibold leading-4 text-slate-700">
            v2.0 Latest Version
          </div> -->
          <div class="text-center md:text-left">
            <span class="text-lg font-bold text-slate-900 md:text-xl md:leading-relaxed dark:text-slate-100"
              >Hey <span
                aria-label="wave"
                role="img"
                >👋</span
              > I'm</span
            >
            <h1 class="my-4 font-serif text-5xl font-extrabold md:text-6xl lg:text-7xl">
              <span
                class="bg-linear-to-br from-sky-300/40 via-sky-300/40 to-sky-500/40 text-slate-900 transition-colors dark:from-sky-100 dark:to-sky-400 dark:bg-clip-text dark:text-transparent"
                >David</span
              >
            </h1>
          </div>
          <h2
            class="text-md mx-auto px-12 font-sans text-slate-600 md:px-0 md:text-xl md:leading-relaxed dark:text-slate-200">
            I believe every problem presents an opportunity.<br class="" />
            I'm a <strong>Customer Success</strong> professional, specialized in B2B SaaS with a passion for people & technology.
            Currently helping secure the world's cloud @ <a
              class="cursor-alias text-sky-600 hover:text-sky-500 dark:text-sky-300 dark:hover:text-sky-200"
              href="https://www.wiz.io"
              >Wiz</a
            >
          </h2>
          <div
            class="flex flex-col space-y-2 pt-10 pb-16 sm:flex-row sm:items-center sm:justify-center sm:space-y-0 sm:space-x-2 md:items-start md:justify-start">
            <Button
              link="/blog"
              title="Read Blog"
              icon="tabler:news"
              size="lg"
              umami="blog-button"
            />
            <Button
              link="https://www.linkedin.com/in/ddlawson/"
              title="View Profile"
              icon="tabler:brand-linkedin"
              variant="outline"
              size="lg"
              umami="profile-button"
              target="_blank"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
