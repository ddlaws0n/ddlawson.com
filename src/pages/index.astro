---
import { SITE, SOCIAL } from '@/config';
import PageLayout from '@/layouts/PageLayout.astro';
import Button from '@/components/Button.astro';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import HeroImage from '@/assets/images/david-d-lawson-profile.jpg';
const meta = {
  title: SITE.title,
  description: SITE.description,
  dontUseTitleTemplate: true,
  canonical: SITE.origin,
};
---

<PageLayout {meta}>
  <section class="overflow-hidden">
    <div class="relative container mx-auto px-4 py-16 md:py-24 lg:px-8 xl:max-w-7xl">
      <div class="grid grid-cols-1 gap-12 md:grid-cols-2">
        <div class="col-span-1 place-self-center md:order-last">
          <div class="relative mx-auto mb-10 w-64 md:mb-0 md:w-80 lg:w-96">
            <div
              class="aspect-square overflow-hidden rounded-full border-4 border-white shadow-xl dark:border-slate-800">
              <div
                class="absolute inset-0 rounded-full bg-gradient-to-tr from-sky-200 to-sky-400 opacity-10 dark:opacity-30">
              </div>
              <Image
                src={HeroImage}
                alt="David D Lawson Profile Photo"
                format="webp"
                width={640}
                height={640}
                class="h-full w-full object-cover object-center"
              />
            </div>
          </div>
        </div>
        <div class="col-span-1 flex flex-col justify-center">
          <div class="text-center md:text-left">
            <span class="text-lg font-medium text-slate-800 md:text-xl md:leading-relaxed dark:text-slate-100">
              Hey <span
                aria-label="wave"
                role="img"
                >👋</span
              > I'm
            </span>
            <h1 class="my-4 font-serif text-5xl font-extrabold md:text-6xl lg:text-7xl">
              <span
                class="via-snone bg-gradient-to-r from-sky-200 to-indigo-100 px-2 text-slate-900 dark:via-none dark:from-sky-100 dark:to-indigo-500 dark:bg-clip-text dark:text-transparent">
                David
              </span>
            </h1>

            <!-- More prominent subheader -->
            <p class="mt-6 mb-4 text-xl font-bold text-slate-800 md:text-2xl lg:text-3xl dark:text-slate-100">
              I believe every problem presents an opportunity.
            </p>

            <p
              class="text-md mx-auto font-sans text-slate-600 md:mx-0 md:text-lg md:leading-relaxed dark:text-slate-300">
              I'm a <strong>Customer Success</strong> professional, specialized in B2B SaaS with a passion for people & technology.
              Currently helping secure the world's cloud @ <a
                class="cursor-alias text-sky-600 hover:text-sky-500 dark:text-sky-300 dark:hover:text-sky-200"
                href="https://www.wiz.io"
                >Wiz</a
              >
            </p>
          </div>

          <!-- Social media icons and CTA -->
          <div class="mt-8 flex flex-col space-y-6 md:space-y-8">
            <!-- CTA -->
            <div class="flex justify-center md:justify-start">
              <Button
                link="/writing"
                title="Explore"
                icon="tabler:news"
                size="lg"
                variant="outline"
                umami="writing-button"
              />
            </div>

            <!-- Social media icons -->
            <div class="flex items-center justify-center space-x-5 md:justify-start">
              {
                SOCIAL.map(({ name, link, ariaLabel }) => (
                  <a
                    href={link}
                    target="_blank"
                    class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 text-slate-700 transition-colors hover:bg-sky-100 hover:text-sky-600 dark:bg-slate-800 dark:text-slate-300 dark:hover:bg-slate-700 dark:hover:text-sky-300"
                    aria-label={ariaLabel}>
                    <Icon
                      name={name}
                      class="h-5 w-5"
                    />
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
