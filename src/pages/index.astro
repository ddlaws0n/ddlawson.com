---
import Beliefs from "@/components/Beliefs.astro";
import Footer from "@/components/Footer.astro";
import Hero from "@/components/Hero.astro";
import Nav from "@/components/Nav.astro";
import Projects from "@/components/Projects.astro";
import Quote from "@/components/Quote.astro";
import RecentWriting from "@/components/RecentWriting.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  meta={{
    title: "David D Lawson",
    description:
      "Building bridges between technology and the humans who need it.",
    noindex: true,
    nofollow: true,
  }}
>
  <div
    class="font-body bg-background text-text relative min-h-screen overflow-x-hidden"
  >
    <div class="m-noise"></div>
    <Nav />
    <main id="main-content" class="max-w-content mx-auto px-(--m-gutter)">
      <Hero />
      <Quote />
      <Beliefs />
      <RecentWriting />
      <Projects />
    </main>
    <Footer />
  </div>
</BaseLayout>
