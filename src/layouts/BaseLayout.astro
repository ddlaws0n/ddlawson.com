---
import '@/assets/styles/base.css';
import GrainOverlay from '@/components/GrainOverlay.astro';
import MetaTags from '@/components/MetaTags.astro';
import { SITE } from '@/site.config';
import type { MetaSEO } from '@/types';
import SpeedInsights from '@vercel/speed-insights/astro';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  meta?: MetaSEO;
}

const { meta = {} } = Astro.props;
const { language = 'en-gb' } = SITE;
---

<!doctype html>
<html lang={language} dir="ltr" class="h-full scroll-smooth motion-reduce:scroll-auto" style="color-scheme: dark;">
  <head>
    <MetaTags {...meta} />
    <ClientRouter />
  </head>

  <body class="flex min-h-screen flex-col antialiased">
    <a
      href="#main-content"
      class="focus:z-modal sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:rounded focus:bg-accent focus:px-4 focus:py-2 focus:font-body focus:text-small focus:font-semibold focus:text-bg focus:no-underline"
    >
      Skip to main content
    </a>
    <GrainOverlay />
    <slot />
    <SpeedInsights />
    <script src="../scripts/reveal.ts"></script>
    <script src="../scripts/magnetic.ts"></script>
  </body>
</html>
