---
import '@/assets/styles/base.css';
import BackgroundBlur from '@/components/BackgroundBlur.astro';
import MetaTags from '@/components/MetaTags.astro';
import { SITE } from '@/site.config';
import type { MetaSEO } from '@/types';
import SpeedInsights from '@vercel/speed-insights/astro';
import { ClientRouter } from 'astro:transitions';
export interface Props {
  meta?: MetaSEO;
}
const { meta = {} } = Astro.props;
const { language = 'en-gb' } = SITE;
---

<!doctype html>
<html lang={language} dir="ltr" class="h-full scroll-smooth motion-reduce:scroll-auto">
  <head>
    <MetaTags {...meta} />
    <ClientRouter />
  </head>

  <body class="flex min-h-screen flex-col bg-slate-50 antialiased dark:bg-slate-950 dark:text-slate-50">
    <BackgroundBlur />
    <slot />
    <SpeedInsights />
  </body>
</html>
