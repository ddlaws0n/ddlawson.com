---
import type { Role } from '@/types';

interface Props {
  roles: Role[];
}

const { roles } = Astro.props;
---

<div class="role-tabs-container mt-4 flex flex-wrap gap-2 lg:mt-6 lg:flex-col lg:items-start lg:gap-2">
  {
    roles.map((role, roleIndex) => (
      <button
        type="button"
        class:list={[
          'role-tab',
          'min-h-[44px] w-full rounded-md px-3 py-2 text-left text-sm font-medium lg:rounded-lg lg:px-4 lg:py-2.5',
          'border-l-2 border-transparent text-text-muted transition-colors duration-200 hover:text-text',
          {
            'active-tab': roleIndex === 0,
          },
        ]}
        data-role-index={roleIndex}
        aria-selected={roleIndex === 0 ? 'true' : 'false'}
      >
        {role.title}
      </button>
    ))
  }
</div>

<style>
  .role-tab {
    background-color: transparent;
  }
  .role-tab:hover {
    background-color: color-mix(in srgb, var(--color-text) 4%, transparent);
  }
  .role-tab.active-tab {
    border-left-color: var(--color-accent);
    color: var(--color-accent);
    background-color: color-mix(in srgb, var(--color-accent) 8%, transparent);
  }
  .role-tab.active-tab:hover {
    background-color: color-mix(in srgb, var(--color-accent) 12%, transparent);
  }
</style>
