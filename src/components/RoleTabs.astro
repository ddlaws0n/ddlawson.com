---
import type { Role } from '@/types';

interface Props {
  roles: Role[];
}

const { roles } = Astro.props;
---

<div class="role-tabs-container mt-4 flex flex-wrap gap-2 lg:mt-6 lg:flex-col lg:items-start lg:gap-3">
  {
    roles.map((role, roleIndex) => (
      <button
        type="button"
        class:list={[
          'role-tab',
          'w-full rounded-md px-3 py-1.5 text-left text-sm font-medium lg:rounded-lg lg:px-4 lg:py-2', // Adjusted padding/rounding for vertical
          // Base styles - active state handled by CSS variables and 'active-tab' class
          'bg-[--inactive-tab-bg] text-[--inactive-tab-text] hover:bg-[--hover-tab-bg] dark:bg-[--dark-inactive-tab-bg] dark:text-[--dark-inactive-tab-text] dark:hover:bg-[--dark-hover-tab-bg]',
          {
            'active-tab': roleIndex === 0, // Add class initially, styling comes from CSS
          },
        ]}
        data-role-index={roleIndex}
        aria-selected={roleIndex === 0 ? 'true' : 'false'}>
        {role.title}
      </button>
    ))
  }
</div>

<style>
  /* Define CSS Variables for tab states */
  .role-tabs-container {
    /* Light Mode */
    --active-tab-bg: var(--color-sky-600); /* Fallback solid color */
    --active-tab-bg-image: linear-gradient(to right, var(--color-sky-500), var(--color-sky-600));
    --active-tab-text: var(--color-white);
    --inactive-tab-bg: var(--color-sky-100);
    --inactive-tab-text: var(--color-sky-700);
    --hover-tab-bg: var(--color-sky-200);
    /* Dark Mode */
    --dark-active-tab-bg: var(--color-sky-700); /* Fallback solid color */
    --dark-active-tab-bg-image: linear-gradient(to right, var(--color-sky-600), var(--color-sky-700));
    --dark-active-tab-text: var(--color-white);
    --dark-inactive-tab-bg: var(--color-sky-900);
    --dark-inactive-tab-text: var(--color-sky-300);
    --dark-hover-tab-bg: var(--color-sky-800);
  }

  /* Apply base styles using variables */
  .role-tab {
    background-color: var(--inactive-tab-bg);
    color: var(--inactive-tab-text);
    /* Removed transition */
  }
  .role-tab:hover {
    background-color: var(--hover-tab-bg);
  }

  /* Apply active styles using variables */
  .role-tab.active-tab {
    color: var(--active-tab-text);
    background-color: var(--active-tab-bg); /* Fallback */
    background-image: var(--active-tab-bg-image);
  }
  .role-tab.active-tab:hover {
    /* Keep active style on hover */
    background-color: var(--active-tab-bg);
    background-image: var(--active-tab-bg-image);
  }

  /* Dark mode overrides */
  :global(html.dark) .role-tabs-container {
    /* Re-scope variables for dark mode */
    --active-tab-bg: var(--dark-active-tab-bg);
    --active-tab-bg-image: var(--dark-active-tab-bg-image);
    --active-tab-text: var(--dark-active-tab-text);
    --inactive-tab-bg: var(--dark-inactive-tab-bg);
    --inactive-tab-text: var(--dark-inactive-tab-text);
    --hover-tab-bg: var(--dark-hover-tab-bg);
  }
</style>
