---
import { NAV } from "@/site.config";
---

<div class="sticky top-0 z-100 border-b border-border bg-bg/82 backdrop-blur-[16px] backdrop-saturate-[1.2]">
	<nav class="mx-auto flex max-w-[var(--spacing-content)] items-center justify-between px-[var(--m-gutter)] py-4">
		<div class="flex items-center gap-5">
			<a href="/" class="font-display text-[1.15rem] font-bold tracking-[0.04em] text-text no-underline transition-colors duration-300 hover:text-blue">DDL</a>
			<span class="nav-status flex items-center gap-[0.45rem] text-[0.58rem] font-light tracking-[0.06em] text-text-muted">
				<span class="size-[5px] rounded-full bg-blue shadow-[0_0_6px_oklch(64.8%_0.081_195_/_0.4)] animate-pulse-dot"></span>
				London, UK
			</span>
		</div>
		<ul class="flex gap-8 list-none m-0 p-0 max-md:gap-5">
			{NAV.map((item) => (
				<li><a href={item.href} class="nav-link font-body text-[0.75rem] font-normal tracking-[0.1em] uppercase text-text-muted no-underline transition-colors duration-250 relative hover:text-text max-md:text-[0.68rem]">{item.name}</a></li>
			))}
		</ul>
	</nav>
</div>

<style>
	.nav-status {
		@media (max-width: 768px) {
			display: none;
		}
	}

	.nav-link::after {
		content: "";
		position: absolute;
		bottom: -4px;
		left: 0;
		width: 0;
		height: 1px;
		background: var(--color-blue);
		transition: width 0.3s ease;
	}

	.nav-link:hover::after {
		width: 100%;
	}
</style>
