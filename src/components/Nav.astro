---
import { Icon } from "astro-icon/components";
import { nav } from "@/site.config";

// 1. Get the current path from Astro.url
const pathname = Astro.url.pathname;
---

<div
  class="border-border bg-background/82 sticky top-0 z-100 border-b backdrop-blur-lg backdrop-saturate-[1.2]"
>
  <nav
    aria-label="Main navigation"
    class="max-w-content mx-auto flex items-center justify-between px-(--m-gutter) py-3 sm:py-4"
  >
    <a
      href="/"
      class="group text-text inline-flex shrink-0 no-underline transition-all duration-300 hover:-translate-y-px hover:opacity-85"
      aria-label="Home"
    >
      <Icon
        name="dl_dot"
        class="h-[1.1rem] w-auto transition-[filter] duration-300 [&_circle]:group-hover:drop-shadow-(--shadow-logo-teal)"
      />
    </a>

    <ul
      class="m-0 flex list-none flex-wrap justify-end gap-x-3.5 gap-y-1 p-0 sm:gap-5 md:gap-8"
    >
      {
        nav.map((item) => {
          // 2. Determine if the current link is active.
          // If it's the home page ('/'), it needs an exact match.
          // Otherwise, we use startsWith() so a route like '/writing/my-post' keeps the '/writing' nav item active.
          const isActive =
            item.href === "/"
              ? pathname === "/"
              : pathname.startsWith(item.href);

          return (
            <li>
              <a
                href={item.href}
                aria-current={isActive ? "page" : undefined}
                class:list={[
                  // Base classes applied to all links
                  "font-body lg:text-caption relative block py-2 text-detail font-normal tracking-wider uppercase no-underline transition-colors duration-250 sm:text-xs sm:tracking-widest",
                  "after:bg-teal after:absolute after:bottom-1 after:left-0 after:h-px after:transition-[width] after:duration-300 sm:after:-bottom-1",

                  // 3. Conditional classes based on active state
                  isActive
                    ? "text-text after:w-full" // Active state: bright text, permanent underline
                    : "text-text-muted hover:text-text after:w-0 hover:after:w-full", // Inactive state: muted text, underline on hover
                ]}
              >
                {item.name}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</div>
