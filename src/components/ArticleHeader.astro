---
import TagPill from '@/components/TagPill.astro';
import { getFormattedDate } from '@/utils';

interface Props {
  title: string;
  date: Date;
  readingTime: string;
  tags?: string[];
}

const { title, date, readingTime, tags } = Astro.props;
---

<section class="px-12 py-16 max-sm:px-6">
  <h1 class="mb-6 font-display text-title leading-[1.15] font-bold text-text">
    {title}
  </h1>
  <div class="flex flex-wrap items-center gap-4 font-body text-caption text-text-muted">
    <time datetime={date instanceof Date ? date.toISOString() : date}>
      {getFormattedDate(date)}
    </time>
    <span>{readingTime}</span>
    {tags && tags.map((tag) => <TagPill tag={tag} />)}
  </div>
</section>
