---
import { Icon } from 'astro-icon/components';
import { tv } from 'tailwind-variants';

const container = tv({
  base: ['container mx-auto max-w-2xl lg:max-w-6xl xl:max-w-7xl'],
  variants: {
    variant: {
      normal: ['py-12 lg:py-24 '],
      tight: ['py-0 md:py-2'],
    },
  },
  defaultVariants: {
    variant: 'normal',
  },
});

const { title, subtitle, divider, icon, variant, class: className, ...props } = Astro.props;
---

<div
  {...props}
  class:list={[container({ variant }), className]}>
  {
    (title || subtitle || icon) && (
      <div class="mb-12 text-center">
        {icon && (
          <div class="flex justify-center">
            <div class="mb-4 rounded-lg border border-sky-500 bg-gradient-to-br from-sky-100 to-indigo-200 p-2 dark:from-sky-900 dark:to-indigo-900">
              <Icon
                name={icon}
                class="size-6 text-sky-600 dark:text-sky-400"
              />
            </div>
          </div>
        )}
        {title && (
          <h1 class="mb-4 text-4xl font-extrabold text-slate-900 md:text-5xl lg:text-6xl dark:text-slate-100">
            {title}
          </h1>
        )}
        {subtitle && <p class="mx-auto max-w-3xl text-xl text-slate-950/75 dark:text-slate-300">{subtitle}</p>}
      </div>
    )
  }
  {divider && <hr class="my-18 h-px border-none bg-gradient-to-r from-transparent via-slate-300 to-transparent" />}
  <slot />
</div>
