---
/**
 * BentoCard component
 * Styled to match Tailwind example with layered structure
 * Enhanced with hover effects, improved visual hierarchy, and better responsive design
 */
import { Icon } from 'astro-icon/components';

const { title, content, image, footer, icon = 'tabler:star', href, className = '' } = Astro.props;
---

{
  href ? (
    <a
      href={href}
      class={`group relative block overflow-hidden rounded-2xl bg-white shadow ring-1 ring-black/5 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-xl hover:ring-black/10 focus:ring-2 focus:ring-sky-400 focus:outline-none ${className}`}
      tabindex="0"
      aria-label={title}>
      <div class="relative z-10 p-6 sm:p-8">
        {title && (
          <div class="flex items-center gap-2">
            {icon && (
              <Icon
                name={icon}
                class="h-5 w-5 text-blue-500"
                aria-hidden="true"
              />
            )}
            <h3 class="text-lg font-semibold tracking-tight text-gray-900">{title}</h3>
          </div>
        )}
        {content && <p class="mt-2 text-sm text-gray-600">{content}</p>}
        <slot />
      </div>

      {image && (
        <div class="relative z-0 mt-4 overflow-hidden">
          <img
            src={image}
            alt=""
            class="w-full rounded-xl object-cover transition-transform duration-500 ease-in-out group-hover:scale-105"
          />
        </div>
      )}

      {footer && <div class="relative z-10 px-6 pb-6 text-sm text-gray-500">{footer}</div>}

      <div
        class="animate-glow pointer-events-none absolute inset-0 z-0 opacity-5 transition-all duration-500 ease-in-out group-hover:opacity-10"
        style="background: radial-gradient(circle at top left, #3b82f6, #9333ea);"
      />
    </a>
  ) : (
    <div
      class={`group relative overflow-hidden rounded-2xl bg-white shadow ring-1 ring-black/5 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-xl hover:ring-black/10 focus:ring-2 focus:ring-sky-400 focus:outline-none ${className}`}
      tabindex="0"
      aria-label={title}>
      <div class="relative z-10 p-6 sm:p-8">
        {title && (
          <div class="flex items-center gap-2">
            {icon && (
              <Icon
                name={icon}
                class="h-5 w-5 text-blue-500"
                aria-hidden="true"
              />
            )}
            <h3 class="text-lg font-semibold tracking-tight text-gray-900">{title}</h3>
          </div>
        )}
        {content && <p class="mt-2 text-sm text-gray-600">{content}</p>}
        <slot />
      </div>

      {image && (
        <div class="relative z-0 mt-4 overflow-hidden">
          <img
            src={image}
            alt=""
            class="w-full rounded-xl object-cover transition-transform duration-500 ease-in-out group-hover:scale-105"
          />
        </div>
      )}

      {footer && <div class="relative z-10 px-6 pb-6 text-sm text-gray-500">{footer}</div>}

      <div
        class="animate-glow pointer-events-none absolute inset-0 z-0 opacity-5 transition-all duration-500 ease-in-out group-hover:opacity-10"
        style="background: radial-gradient(circle at top left, #3b82f6, #9333ea);"
      />
    </div>
  )
}

<style>
  @keyframes glow {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.05;
    }
    50% {
      transform: scale(1.05);
      opacity: 0.1;
    }
  }
  .animate-glow {
    animation: glow 6s ease-in-out infinite;
  }
</style>
