---
const projects = [
  {
    tag: "Website",
    title: "ddlawson.com",
    desc: "This website. Built with Astro, deployed on Cloudflare.",
  },
  {
    tag: "Internal Tool",
    title: "TAM Toolkit",
    desc: "Tools for technical account management workflows.",
  },
  {
    tag: "Dashboard",
    title: "Security Posture",
    desc: "Customer-facing security metrics visualization.",
  },
  {
    tag: "Experiment",
    title: "AI Workflows",
    desc: "Exploring LLM-powered automation for customer success.",
  },
];
---

<section class="m-section m-reveal" id="projects">
  <div class="m-label">
    <span
      class="font-display text-text-muted lg:text-label text-xs font-semibold tracking-[0.24em] whitespace-nowrap uppercase"
      >What I'm Building</span
    >
    <div class="from-border-hover h-px flex-1 bg-linear-to-r to-transparent/80">
    </div>
  </div>

  <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
    {
      projects.map((p) => (
        <a
          href="#"
          tabindex="-1"
          aria-disabled="true"
          class="group bg-surface border-border hover:bg-elevated hover:border-border-hover before:via-teal relative block overflow-hidden rounded-md border p-5 text-inherit no-underline transition-all duration-350 before:absolute before:inset-x-0 before:top-0 before:h-px before:bg-linear-to-r before:from-transparent before:to-transparent before:opacity-0 before:transition-opacity before:duration-350 hover:-translate-y-0.5 hover:shadow-[0_8px_32px_oklch(0%_0_0/0.2),0_0_0_1px_var(--color-border-hover)] hover:before:opacity-100 sm:p-6 md:p-9 md:px-10"
        >
          <div class="font-display text-text-muted group-hover:text-teal lg:text-detail mb-3.5 text-xs font-semibold tracking-[0.2em] uppercase transition-colors duration-350">
            {p.tag}
          </div>
          <h3 class="font-display text-text mb-2.5 text-lg leading-[1.3] font-semibold">
            {p.title}
          </h3>
          <p class="font-body text-prose text-text-secondary font-light">
            {p.desc}
          </p>
          <span class="text-text-muted group-hover:text-teal mt-5 inline-block text-[0.9rem] transition-all duration-300 group-hover:translate-x-1.5">
            &rarr;
          </span>
        </a>
      ))
    }
  </div>
</section>
