---
import { SOCIAL } from "@/site.config";
---

<div class="border-t border-border mt-8 bg-bg">
	<footer class="mx-auto flex max-w-[var(--spacing-content)] items-center justify-between px-[var(--m-gutter)] py-8 max-md:flex-col max-md:gap-3 max-md:text-center">
		<span class="text-[0.68rem] font-light text-text-muted">&copy; {new Date().getFullYear()} David D. Lawson</span>
		<ul class="flex gap-7 list-none m-0 p-0">
			<li><a href="mailto:hello@ddlawson.com" class="text-[0.68rem] font-normal text-text-muted no-underline transition-colors duration-250 hover:text-blue">Email</a></li>
			{SOCIAL.map((s) => (
				<li>
					<a href={s.link} target="_blank" rel="noopener" class="text-[0.68rem] font-normal text-text-muted no-underline transition-colors duration-250 hover:text-blue">
						{s.ariaLabel}
					</a>
				</li>
			))}
		</ul>
	</footer>
</div>
