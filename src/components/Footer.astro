---
import { SOCIAL } from '@/site.config';

const currentYear = new Date().getFullYear();

const footerNav = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Writing', href: '/writing' },
  { name: 'Contact', href: '/contact' },
];
---

<footer class="border-t border-border">
  <div class="mx-auto grid max-w-[1400px] gap-12 px-12 pt-16 pb-12" style="grid-template-columns: 1.5fr 1fr 1fr;">
    <!-- Col 1: Brand -->
    <div class="flex flex-col gap-3">
      <span class="font-display text-[1.1rem] font-bold text-text opacity-15">David D. Lawson</span>
      <p class="max-w-[28ch] font-body text-small leading-relaxed font-light text-text-muted opacity-50">
        Building bridges between technology and the humans who need it.
      </p>
    </div>

    <!-- Col 2: Navigate -->
    <div>
      <p class="mb-5 font-display text-[0.58rem] font-bold tracking-[0.2em] text-text-muted uppercase opacity-35">
        Navigate
      </p>
      <ul class="m-0 flex list-none flex-col gap-2.5 p-0">
        {
          footerNav.map(({ name, href }) => (
            <li>
              <a
                href={href}
                class="font-body text-small font-light text-text-muted no-underline transition-colors duration-200 hover:text-text"
              >
                {name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Col 3: Elsewhere -->
    <div>
      <p class="mb-5 font-display text-[0.58rem] font-bold tracking-[0.2em] text-text-muted uppercase opacity-35">
        Elsewhere
      </p>
      <ul class="m-0 flex list-none flex-col gap-2.5 p-0">
        {
          SOCIAL.map(({ link, ariaLabel }) => (
            <li>
              <a
                href={link}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={ariaLabel}
                class="font-body text-small font-light text-text-muted no-underline transition-colors duration-200 hover:text-text"
              >
                {ariaLabel}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Copyright -->
    <p
      class="mt-4 font-body text-caption font-light tracking-[0.08em] text-text-muted opacity-25"
      style="grid-column: 1 / -1;"
    >
      &copy; {currentYear} David D. Lawson. All rights reserved.
    </p>
  </div>
</footer>

<style>
  @media (max-width: 640px) {
    footer > div {
      grid-template-columns: 1fr !important;
    }
  }
</style>
