---
import { SOCIAL } from '@/site.config';

const currentYear = new Date().getFullYear();

const footerNav = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Writing', href: '/writing' },
  { name: 'Contact', href: '/contact' },
];
---

<footer class="border-t border-border">
  <div
    class="mx-auto grid max-w-[1400px] grid-cols-1 gap-12 px-12 pt-16 pb-12 max-sm:px-6 sm:grid-cols-[1.5fr_1fr_1fr]"
  >
    <!-- Col 1: Brand -->
    <div class="flex flex-col gap-3">
      <span class="font-display text-body-lg font-bold text-text opacity-15">David D. Lawson</span>
      <p class="max-w-[28ch] font-body text-small leading-relaxed font-light text-text-muted opacity-50">
        Building bridges between technology and the humans who need it.
      </p>
    </div>

    <!-- Col 2: Navigate -->
    <div>
      <p class="mb-5 font-display text-caption font-bold tracking-label text-text-muted uppercase opacity-35">
        Navigate
      </p>
      <ul class="m-0 flex list-none flex-col gap-2.5 p-0">
        {
          footerNav.map(({ name, href }) => (
            <li>
              <a
                href={href}
                class="flex min-h-[44px] items-center font-body text-small font-light text-text-muted no-underline transition-colors duration-200 hover:text-text"
              >
                {name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Col 3: Elsewhere -->
    <div>
      <p class="mb-5 font-display text-caption font-bold tracking-label text-text-muted uppercase opacity-35">
        Elsewhere
      </p>
      <ul class="m-0 flex list-none flex-col gap-2.5 p-0">
        {
          SOCIAL.map(({ link, ariaLabel }) => (
            <li>
              <a
                href={link}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={ariaLabel}
                class="flex min-h-[44px] items-center font-body text-small font-light text-text-muted no-underline transition-colors duration-200 hover:text-text"
              >
                {ariaLabel}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Copyright -->
    <p class="col-span-full mt-4 font-body text-caption font-light tracking-tight text-text-muted opacity-25">
      &copy; {currentYear} David D. Lawson. All rights reserved.
    </p>
  </div>
</footer>
