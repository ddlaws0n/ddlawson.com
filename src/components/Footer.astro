---
import { Icon } from "astro-icon/components";
import { conf, social } from "@/site.config";
---

<div class="border-border bg-background mt-8 border-t">
  <footer
    class="max-w-content mx-auto flex flex-col items-center gap-3 px-(--m-gutter) py-8 text-center md:flex-row md:justify-between md:gap-0 md:text-left"
  >
    <span class="text-caption text-text-muted font-light"
      >&copy; {new Date().getFullYear()} {conf.site.name}</span
    >
    <ul class="m-0 flex list-none items-center gap-7 p-0">
      {
        social.map((s) => {
          const isEmail = s.link.startsWith("mailto:");
          const linkClass =
            "text-text-muted hover:text-teal inline-flex items-center justify-center p-2.5 transition-colors duration-250";
          if (isEmail) {
            const [user, domain] = s.link.replace("mailto:", "").split("@");
            return (
              <li>
                <a
                  href="#"
                  data-u={user}
                  data-d={domain}
                  aria-label={s.ariaLabel}
                  data-umami-event="email-click"
                  data-umami-event-location="footer"
                  class:list={["js-email", linkClass]}
                >
                  <Icon name={s.name} class="size-[0.9rem]" />
                </a>
              </li>
            );
          }
          return (
            <li>
              <a
                href={s.link}
                target="_blank"
                rel="external noopener noreferrer"
                aria-label={s.ariaLabel}
                data-umami-event="social-click"
                data-umami-event-platform={s.ariaLabel}
                data-umami-event-location="footer"
                class={linkClass}
              >
                <Icon name={s.name} class="size-[0.9rem]" />
                <span class="sr-only">(opens in new tab)</span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </footer>
</div>

<script>
	function hydrateEmail() {
		document.querySelectorAll<HTMLAnchorElement>(".js-email").forEach((el) => {
			const u = el.dataset.u;
			const d = el.dataset.d;
			if (u && d) el.href = `mailto:${u}@${d}`;
		});
	}
	hydrateEmail();
	document.addEventListener("astro:after-swap", hydrateEmail);
</script>
