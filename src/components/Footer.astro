---
import { NAV, SOCIAL } from '@/config';
import { Icon } from 'astro-icon/components';

const currentYear = new Date().getFullYear();
---

<footer class="mt-auto border-t border-slate-200 dark:border-slate-800">
  <div class="mx-auto max-w-7xl px-6 py-14 sm:py-16 lg:px-8">
    <nav class="mb-10 flex flex-wrap justify-center gap-x-10 gap-y-4" aria-label="Footer">
      {
        NAV.map(({ name, href }) => (
          <div>
            <a
              href={href}
              class="text-sm leading-6 font-medium text-slate-600 transition-colors hover:text-sky-600 dark:text-slate-300 dark:hover:text-sky-300"
            >
              {name}
            </a>
          </div>
        ))
      }
      <div>
        <button class="cursor-not-allowed text-sm leading-6 font-medium text-slate-400 dark:text-slate-600" disabled
          >Projects</button
        >
        <span
          class="ml-2 inline-flex items-center rounded-full bg-slate-100 px-2 py-0.5 text-[.6125rem] font-medium text-slate-500 uppercase dark:bg-slate-800 dark:text-slate-400"
          >Soon</span
        >
      </div>
    </nav>

    <div class="mt-8 flex justify-center space-x-8">
      {
        SOCIAL.map(({ name, link, ariaLabel }) => (
          <a
            href={link}
            target="_blank"
            aria-label={ariaLabel}
            class="inline-flex h-10 w-10 items-center justify-center rounded-full text-slate-500 transition-colors hover:bg-sky-100 hover:text-sky-600 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-sky-300"
          >
            <span class="sr-only">{ariaLabel}</span>
            <Icon name={name} class="h-5 w-5" />
          </a>
        ))
      }
    </div>

    <div class="mt-10 border-t border-slate-200 pt-8 dark:border-slate-800">
      <p class="text-center text-sm text-slate-500 dark:text-slate-400">
        &copy; {currentYear} David D Lawson. Got any feedback? <span
          data-feedback-fish
          class="cursor-pointer font-medium text-sky-600 hover:text-sky-500 dark:text-sky-400 dark:hover:text-sky-300"
          >Let me know!</span
        >
      </p>
    </div>
  </div>
</footer>
