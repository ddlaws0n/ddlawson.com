---
import heroPhoto from '@/assets/images/david-d-lawson-full.png';
import { Image } from 'astro:assets';
---

<section class="hero">
  <div class="hero-text">
    <p class="hero-eyebrow mb-8 font-display text-caption font-semibold tracking-wide text-text-muted uppercase">
      Customer Success + AI
    </p>

    <h1
      class="m-0 font-display text-hero leading-[0.92] font-extrabold text-text"
      style="letter-spacing: var(--tracking-hero);"
    >
      <span class="line line-1">David</span>
      <span class="line line-2">D. Lawson</span>
    </h1>

    <div class="hero-rule my-10 h-0.5 w-[100px] bg-accent"></div>

    <p class="hero-desc max-w-[36ch] font-body text-body-lg leading-relaxed font-light text-text-secondary">
      Building bridges between technology and the humans who need it. Customer Success leader, AI practitioner, writer.
    </p>
  </div>

  <div class="hero-photo-wrap">
    <Image
      src={heroPhoto}
      alt="David D. Lawson"
      widths={[600, 900, 1200]}
      sizes="(max-width: 900px) 100vw, 45vw"
      loading="eager"
      class="hero-img"
    />
    <div class="photo-glow"></div>
    <div class="photo-fade-bottom"></div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    min-height: 100dvh;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    position: relative;
    overflow: hidden;
  }

  .hero-text {
    padding: 0 4rem 6rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    z-index: 2;
  }

  .hero-photo-wrap {
    position: relative;
    overflow: hidden;
    min-height: 0;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    mask-image: linear-gradient(to right, transparent, black 25%);
    -webkit-mask-image: linear-gradient(to right, transparent, black 25%);
  }

  .photo-glow {
    position: absolute;
    bottom: -10%;
    left: 10%;
    width: 80%;
    height: 60%;
    background: radial-gradient(ellipse, rgba(74, 127, 212, 0.08) 0%, transparent 70%);
    z-index: 1;
    pointer-events: none;
  }

  .photo-fade-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 30%;
    background-color: var(--color-bg);
    mask-image: linear-gradient(to top, black, transparent);
    -webkit-mask-image: linear-gradient(to top, black, transparent);
    z-index: 4;
    pointer-events: none;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-text {
      padding: 4rem 1.5rem 3rem;
      order: 2;
    }

    .hero-photo-wrap {
      order: 1;
      max-height: 50vh;
    }
  }
</style>
