---
import { Image } from "astro:assets";
import heroPhoto from "@/assets/img/david-lawson.png";
import { SOCIAL } from "@/site.config";
---

<section class="m-hero" id="about">
    <div class="m-hero-text">
        <span class="m-hero-eyebrow"
            >TAM Leader &middot; Builder &middot; Writer</span
        >
        <h1 class="m-hero-name">
            David <span class="thin">D.</span><br />Lawson
        </h1>
        <div class="m-hero-rule"></div>
        <p class="m-hero-desc">
            Building bridges between technology and the humans who need it.
            Manager, Technical Account Management&nbsp;EMEA&nbsp;at&nbsp;Wiz.
        </p>
        <ul class="m-hero-social">
            {
                SOCIAL.map((s) => (
                    <li>
                        <a
                            href={s.link}
                            target="_blank"
                            rel="noopener"
                            aria-label={s.ariaLabel}
                        >
                            {s.ariaLabel}
                        </a>
                    </li>
                ))
            }
        </ul>
    </div>
    <div class="m-hero-photo-wrap">
        <div class="m-hero-photo">
            <Image
                src={heroPhoto}
                alt="David D. Lawson"
                width={720}
                height={960}
                fit="cover"
                position="top"
            />
            <div class="m-hero-photo-fade"></div>
            <div class="m-hero-photo-fade-left"></div>
            <div class="m-hero-photo-accent"></div>
        </div>
        <div class="m-hero-photo-glow"></div>
    </div>
</section>

<style>
    .m-hero {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 4rem;
        align-items: end;
        padding: 5rem 0 4.5rem;
        min-height: 58vh;
        position: relative;
    }

    .m-hero::before {
        content: "";
        position: absolute;
        top: -80px;
        right: -120px;
        width: 600px;
        height: 600px;
        background: radial-gradient(
            ellipse,
            rgba(74, 158, 158, 0.04) 0%,
            transparent 65%
        );
        pointer-events: none;
    }

    .m-hero-text {
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        opacity: 0;
        animation: m-fadeUp 0.8s cubic-bezier(0.23, 1, 0.32, 1) forwards;
    }

    .m-hero-eyebrow {
        font-family: var(--m-display);
        font-size: 0.58rem;
        font-weight: 600;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: var(--m-blue-muted);
        margin-bottom: 1.75rem;
        opacity: 0;
        animation: m-slideIn 0.6s cubic-bezier(0.23, 1, 0.32, 1) forwards 0.2s;
    }

    .m-hero-name {
        font-family: var(--m-display);
        font-size: clamp(3.2rem, 6.5vw, 5.8rem);
        font-weight: 800;
        line-height: 0.92;
        letter-spacing: -0.03em;
        color: var(--m-text);
        margin: 0 0 1.75rem;
    }

    .m-hero-name .thin {
        font-weight: 300;
        color: var(--m-text-secondary);
    }

    .m-hero-rule {
        width: 64px;
        height: 2px;
        background: linear-gradient(90deg, var(--m-blue), transparent);
        margin-bottom: 1.75rem;
        transform: scaleX(0);
        transform-origin: left;
        animation: m-scaleIn 0.6s cubic-bezier(0.23, 1, 0.32, 1) forwards 0.5s;
    }

    .m-hero-desc {
        font-family: var(--m-body);
        font-size: 1.05rem;
        font-weight: 300;
        line-height: 1.75;
        color: var(--m-text-secondary);
        max-width: 36ch;
        margin: 0;
        opacity: 0;
        animation: m-fadeUp 0.7s cubic-bezier(0.23, 1, 0.32, 1) forwards 0.6s;
    }

    .m-hero-social {
        display: flex;
        gap: 1.5rem;
        margin-top: 2.25rem;
        padding: 0;
        list-style: none;
        opacity: 0;
        animation: m-fadeUp 0.6s cubic-bezier(0.23, 1, 0.32, 1) forwards 0.8s;
    }

    .m-hero-social a {
        font-size: 0.72rem;
        font-weight: 400;
        color: var(--m-text-muted);
        text-decoration: none;
        letter-spacing: 0.04em;
        transition:
            color 0.25s ease,
            transform 0.25s ease;
        display: inline-block;
    }

    .m-hero-social a:hover {
        color: var(--m-blue);
        transform: translateY(-1px);
    }

    .m-hero-photo-wrap {
        position: relative;
        opacity: 0;
        animation: m-revealPhoto 0.9s cubic-bezier(0.23, 1, 0.32, 1) forwards
            0.3s;
    }

    .m-hero-photo {
        position: relative;
        overflow: hidden;
        border-radius: 6px;
        aspect-ratio: 3 / 4;
        box-shadow:
            0 8px 40px rgba(0, 0, 0, 0.4),
            0 0 0 1px var(--m-border);
    }

    .m-hero-photo :global(img) {
        width: 100%;
        height: 100%;
        filter: saturate(0.9) contrast(1.02);
    }

    .m-hero-photo-fade {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 40%;
        background: linear-gradient(to top, var(--m-bg), transparent);
        pointer-events: none;
    }

    .m-hero-photo-fade-left {
        position: absolute;
        top: 0;
        left: 0;
        bottom: 0;
        width: 25%;
        background: linear-gradient(
            to right,
            rgba(11, 9, 14, 0.5),
            transparent
        );
        pointer-events: none;
    }

    .m-hero-photo-accent {
        position: absolute;
        bottom: -1px;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, var(--m-blue), transparent 70%);
    }

    .m-hero-photo-glow {
        position: absolute;
        bottom: -20%;
        left: 5%;
        width: 90%;
        height: 50%;
        background: radial-gradient(
            ellipse,
            rgba(74, 158, 158, 0.06) 0%,
            transparent 65%
        );
        pointer-events: none;
    }

    @media (max-width: 900px) {
        .m-hero {
            grid-template-columns: 1fr 220px;
            gap: 2.5rem;
        }
    }

    @media (max-width: 768px) {
        .m-hero {
            grid-template-columns: 1fr;
            min-height: auto;
            padding: 3rem 0;
            gap: 2rem;
        }

        .m-hero-photo-wrap {
            max-width: 240px;
            order: -1;
        }

        .m-hero-photo {
            aspect-ratio: 4 / 5;
        }

        .m-hero-name {
            font-size: clamp(2.4rem, 9vw, 3.5rem);
        }
    }
</style>
