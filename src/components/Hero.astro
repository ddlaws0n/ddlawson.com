---
import { Image } from "astro:assets";
import heroPhoto from "@/assets/img/david-lawson.png";
import { SOCIAL } from "@/site.config";
---

<section class="hero grid grid-cols-[1fr_340px] gap-16 items-end py-20 pb-[4.5rem] min-h-[58vh] relative max-[900px]:grid-cols-[1fr_220px] max-[900px]:gap-10 max-md:grid-cols-1 max-md:min-h-auto max-md:py-12 max-md:gap-8" id="about">
	<div class="flex flex-col justify-end opacity-0 animate-fade-up">
		<span class="font-display text-[0.58rem] font-semibold tracking-[0.24em] uppercase text-blue-muted mb-7 opacity-0 animate-slide-in [animation-delay:0.2s]">
			TAM Leader &middot; Builder &middot; Writer
		</span>
		<h1 class="font-display text-[clamp(3.2rem,6.5vw,5.8rem)] font-extrabold leading-[0.92] tracking-[-0.03em] text-text mb-7 max-md:text-[clamp(2.4rem,9vw,3.5rem)]">
			David <span class="font-light text-text-secondary">D.</span><br />Lawson
		</h1>
		<div class="hero-rule w-16 h-0.5 bg-gradient-to-r from-blue to-transparent mb-7 origin-left [transform:scaleX(0)] animate-scale-in [animation-delay:0.5s]"></div>
		<p class="font-body text-[1.05rem] font-light leading-[1.75] text-text-secondary max-w-[36ch] m-0 opacity-0 animate-fade-up [animation-delay:0.6s]">
			Building bridges between technology and the humans who need it.
			Manager, Technical Account Management&nbsp;EMEA&nbsp;at&nbsp;Wiz.
		</p>
		<ul class="flex gap-6 mt-9 p-0 list-none opacity-0 animate-fade-up [animation-delay:0.8s]">
			{
				SOCIAL.map((s) => (
					<li>
						<a
							href={s.link}
							target="_blank"
							rel="noopener"
							aria-label={s.ariaLabel}
							class="text-[0.72rem] font-normal text-text-muted no-underline tracking-[0.04em] inline-block transition-all duration-250 hover:text-blue hover:-translate-y-px"
						>
							{s.ariaLabel}
						</a>
					</li>
				))
			}
		</ul>
	</div>
	<div class="hero-photo-wrap relative opacity-0 animate-reveal-photo [animation-delay:0.3s] max-md:max-w-60 max-md:order-first">
		<div class="hero-photo relative overflow-hidden rounded-lg aspect-[3/4] shadow-[0_8px_40px_rgba(0,0,0,0.4),0_0_0_1px_var(--color-border)] max-md:aspect-[4/5]">
			<Image
				src={heroPhoto}
				alt="David D. Lawson"
				width={720}
				height={960}
				fit="cover"
				position="top"
			/>
			<div class="hero-photo-fade-left"></div>
			<div class="absolute bottom-[-1px] left-0 right-0 h-0.5 z-10 bg-[linear-gradient(90deg,var(--color-blue),transparent_70%)]"></div>
		</div>
		<div class="hero-photo-glow absolute -bottom-[20%] left-[5%] w-[90%] h-1/2 bg-[radial-gradient(ellipse,oklch(64.8%_0.081_195_/_0.06)_0%,transparent_65%)] pointer-events-none"></div>
	</div>
</section>

<style>
	/* Ambient glow behind hero */
	.hero::before {
		content: "";
		position: absolute;
		top: -80px;
		right: -120px;
		width: 600px;
		height: 600px;
		background: radial-gradient(ellipse, oklch(64.8% 0.081 195 / 0.04) 0%, transparent 65%);
		pointer-events: none;
	}

	.hero-photo :global(img) {
		width: 100%;
		height: 100%;
		filter: saturate(0.9) contrast(1.02);
	}

	/* Bottom fade */
	.hero-photo::after {
		content: "";
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		height: 40%;
		background: linear-gradient(to top, var(--color-bg), transparent);
		pointer-events: none;
	}

	/* Left fade */
	.hero-photo-fade-left {
		position: absolute;
		top: 0;
		left: 0;
		bottom: 0;
		width: 25%;
		background: linear-gradient(to right, oklch(14.5% 0.011 303 / 0.5), transparent);
		pointer-events: none;
	}

</style>
