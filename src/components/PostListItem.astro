---
interface Props {
  date: string;
  title: string;
  tag?: string;
  href: string;
}

const { date, title, tag, href } = Astro.props;
---

<a href={href} class="post-list-item reveal">
  <span class="post-date font-display text-caption font-medium tracking-tight whitespace-nowrap text-text-muted"
    >{date}</span
  >
  <span class="post-title min-w-0 font-body text-body-lg leading-[1.35] font-normal text-text-secondary">{title}</span>
  {
    tag && (
      <span class="post-tag border border-border px-2.5 py-0.5 font-display text-caption font-bold tracking-label whitespace-nowrap text-text-muted uppercase">
        {tag}
      </span>
    )
  }
</a>

<style>
  .post-list-item {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: 2rem;
    align-items: center;
    padding: 1.5rem 1rem;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    transition: background 0.25s;
    position: relative;
    margin: 0 -1rem;
  }

  .post-list-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-list-item:hover {
    background: var(--color-surface);
  }

  .post-list-item:hover .post-title {
    color: var(--color-text);
  }

  .post-list-item:hover .post-date {
    color: var(--color-accent);
  }

  .post-date {
    transition: color 0.25s;
  }

  .post-title {
    transition: color 0.25s;
  }

  @media (max-width: 900px) {
    .post-list-item {
      grid-template-columns: 1fr;
      gap: 0.375rem;
    }

    .post-tag {
      justify-self: start;
    }
  }
</style>
