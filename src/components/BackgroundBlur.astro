---
/**
 * BackgroundBlur.astro
 * Subtle animated blurred backgrounds for page decoration.
 * Animation is defined in src/assets/styles/base.css as 'animate-background-move'.
 */
---

<div
  class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80"
  aria-hidden="true">
  <div
    class="animate-background-move relative left-[calc(50%-11rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr via-none from-sky-400 to-indigo-500 opacity-20 sm:left-[calc(50%-30rem)] sm:w-[72.1875rem] dark:from-sky-500 dark:to-indigo-600 dark:opacity-15"
    style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)">
  </div>
</div>

<div
  class="absolute inset-x-0 top-[30%] -z-10 transform-gpu overflow-hidden blur-3xl"
  aria-hidden="true">
  <div
    class="animate-background-move relative left-[calc(50%+3rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr via-none from-sky-300 to-blue-500 opacity-10 sm:left-[calc(50%+15rem)] sm:w-[72.1875rem] dark:from-sky-400 dark:to-blue-600 dark:opacity-10"
    style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)">
  </div>
</div>
