---
interface Props {
  title: string;
  startDate: string;
  endDate: string;
  summary: string;
  achievements?: string[];
  isCurrent: boolean;
  /** Render mobile variant (smaller sizing/spacing) */
  mobile?: boolean;
  /** Stagger delay in ms for sequential reveal */
  staggerDelay?: number;
}

const {
  title,
  startDate,
  endDate,
  summary,
  achievements,
  isCurrent,
  mobile = false,
  staggerDelay = 0,
} = Astro.props;

const nodeCurrent = mobile
  ? "size-2.5 rounded-full bg-teal animate-pulse-dot shadow-teal-glow-sm"
  : "size-3 rounded-full bg-teal animate-pulse-dot shadow-teal-glow";

const nodePast = mobile
  ? "size-2 rounded-full border border-border-hover bg-surface"
  : "size-2.5 rounded-full border border-border-hover bg-surface";
---

<div
  class:list={[
    "m-reveal group relative",
    mobile ? "pb-10 last:pb-0" : "pb-14 last:pb-0",
  ]}
  style={`--reveal-delay: ${staggerDelay}ms`}
>
  <div
    class:list={[
      "absolute top-[0.35rem] -translate-x-1/2",
      mobile ? "-left-7" : "-left-10",
      isCurrent ? nodeCurrent : nodePast,
    ]}
  >
  </div>

  <div
    class:list={[
      "relative",
      !mobile &&
        "-mx-5 rounded-md border-r-2 px-5 py-4 transition-all duration-300",
      !mobile &&
        (isCurrent
          ? "border-teal/25 bg-teal/3 group-hover:border-teal group-hover:bg-surface"
          : "group-hover:border-teal/40 group-hover:bg-surface border-transparent"),
    ]}
  >
    <h3
      class:list={[
        "font-display text-text m-0 leading-[1.3] font-semibold",
        mobile
          ? "text-base"
          : "group-hover:text-teal-bright text-lg transition-colors duration-300",
      ]}
    >
      {title}
    </h3>
    <p
      class:list={[
        "font-display text-teal-muted mb-0 tracking-[0.2em] uppercase",
        mobile ? "text-detail mt-1" : "mt-1.5 text-caption",
      ]}
    >
      {startDate} — {endDate}
    </p>
    <p
      class:list={[
        "font-body text-prose text-text-secondary mb-0 font-light",
        mobile ? "mt-2.5" : "mt-3 max-w-[52ch]",
      ]}
    >
      {summary}
    </p>
    {
      achievements && achievements.length > 0 && (
        <ul
          class:list={[
            "list-none p-0",
            mobile ? "mt-2.5 space-y-1" : "mt-3 space-y-1.5",
          ]}
        >
          {achievements.map((achievement) => (
            <li class="text-micro text-text-secondary flex items-start gap-2">
              <span class="bg-teal-muted mt-[0.45em] block size-1 shrink-0 rounded-full" />
              {achievement}
            </li>
          ))}
        </ul>
      )
    }
  </div>
</div>
