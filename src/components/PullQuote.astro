---
interface Props {
  quote: string;
  attribution: string;
}

const { quote, attribution } = Astro.props;
---

<section class="reveal border-t border-b border-border bg-surface text-center" style="padding: 5rem 3rem;">
  <p class="quote-text mx-auto mb-6 max-w-[38ch] font-display leading-[1.45] font-medium text-text">
    {quote}
  </p>
  <p class="font-body text-caption font-normal tracking-label text-text-muted uppercase">
    {attribution}
  </p>
</section>

<style>
  .quote-text {
    font-size: clamp(1.4rem, 2.8vw, 2.3rem);
  }
</style>
