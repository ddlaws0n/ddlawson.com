---
interface Props {
  text: string;
  /** Show sideways label on desktop + inline fallback on mobile. Default: inline only. */
  sideways?: boolean;
}

const { text, sideways = false } = Astro.props;
---

{
  sideways ? (
    <>
      {/* Sideways label — desktop only */}
      <span
        class="absolute top-24 left-3 hidden font-display text-caption font-semibold tracking-wide whitespace-nowrap text-text-muted uppercase opacity-20 min-[901px]:block"
        style="writing-mode: vertical-rl; transform: rotate(180deg);"
      >
        {text}
      </span>
      {/* Inline fallback — mobile only */}
      <p class="mb-14 font-display text-caption font-semibold tracking-label text-text-muted uppercase min-[901px]:hidden">
        {text}
      </p>
    </>
  ) : (
    <p class="mb-14 font-display text-caption font-semibold tracking-label text-text-muted uppercase">{text}</p>
  )
}
