---
import defaultImage from '@/assets/images/david-d-lawson-profile.png';
import { SITE } from '@/config';
import type { MetaSEO } from '@/types';
import { getRelativeUrlByFilePath } from '@/utils/directories';
import { AstroSeo } from '@astrolib/seo';
import { Font } from 'astro:assets';

export interface Props extends MetaSEO {
  dontUseTitleTemplate?: boolean;
}

const {
  title = SITE.name,
  description = SITE.description,
  image: _image = defaultImage,
  canonical = Astro.url.pathname,
  noindex = false,
  nofollow = false,
  ogTitle = title,
  ogType = 'website',
  dontUseTitleTemplate = false,
} = Astro.props;

const image =
  typeof _image === 'string'
    ? new URL(_image, Astro.site)
    : _image && typeof _image['src'] !== 'undefined'
      ? new URL(getRelativeUrlByFilePath(_image.src), Astro.site)
      : null;

const appleTouchIcon = {
  src: new URL('/favicon.png?theme=dark&height=192&width=192', Astro.site),
};
---

<meta charset="UTF-8" />
<meta
  name="viewport"
  content="width=device-width"
/>

<Font
  cssVariable="--font-switzer"
  preload
/>

<AstroSeo
  title={title}
  titleTemplate={dontUseTitleTemplate ? '%s' : `%s — ${SITE.name}`}
  description={description}
  canonical={String(canonical)}
  noindex={noindex}
  nofollow={nofollow}
  openGraph={{
    url: String(canonical),
    title: ogTitle,
    description: description,
    type: ogType,
    images: image
      ? [
          {
            url: image.toString(),
            alt: ogTitle,
          },
        ]
      : undefined,
    site_name: 'David D Lawson',
  }}
  twitter={{
    handle: '@ddlawson',
    // site: '@site',
    cardType: image ? 'summary_large_image' : undefined,
  }}
/>

<!-- Dynamic SVG Favicon (light/dark mode switching via JS) -->
<link
  id="favicon-svg"
  rel="icon"
  href="/favicon.svg"
  type="image/svg+xml"
/>

<link
  rel="apple-touch-icon"
  href={appleTouchIcon.src}
/>
<meta
  name="apple-mobile-web-app-title"
  content="D Lawson"
/>
<link
  rel="manifest"
  href="/manifest.json"
/>

<!-- Sitemap -->
<link
  rel="sitemap"
  href="/sitemap-index.xml"
/>

<!-- RSS Feed -->
<link
  rel="alternate"
  type="application/rss+xml"
  title=`${SITE.name} RSS Feed`
  href={new URL('rss.xml', Astro.site)}
/>

<!-- Light/dark mode & Favicon Switching -->
<script is:inline>
  // Function to update favicon links based on theme
  function updateFavicon(doc = document) {
    const isDark = doc.documentElement.classList.contains('dark');
    const svgLink = doc.getElementById('favicon-svg'); // Select only the SVG link

    // Update href attribute based on the theme
    if (svgLink) svgLink.href = isDark ? '/favicon.svg?theme=dark' : '/favicon.svg'; // Update SVG href with query param
  }

  // IIFE: Set initial theme class and call updateFavicon
  (function () {
    const theme = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    if (theme === 'dark' || (!theme && prefersDark)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
    updateFavicon(); // Set initial favicon based on theme
  })();

  // Update theme class and favicon before swapping pages (View Transitions)
  document.addEventListener('astro:before-swap', (event) => {
    // Ensure the new document inherits the current theme class
    if (document.documentElement.classList.contains('dark')) {
      event.newDocument.documentElement.classList.add('dark');
    } else {
      event.newDocument.documentElement.classList.remove('dark');
    }
    updateFavicon(event.newDocument); // Update favicon for the incoming page
  });

  // Function to update the theme toggle button icon (no changes needed here)
  function updateThemeIcon() {
    const isDark = document.documentElement.classList.contains('dark');
    const themeIcon = document.getElementById('theme-icon');
    if (themeIcon) {
      themeIcon.setAttribute('name', isDark ? 'tabler:sun' : 'tabler:moon');
    }
  }

  // Function to attach the theme toggle click handler
  function attachThemeToggleHandler() {
    const toggle = document.querySelector('[data-aw-toggle-color-scheme]');
    if (toggle) {
      toggle.onclick = function () {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        updateThemeIcon(); // Update toggle button icon
        updateFavicon(); // Update favicon when theme is toggled
      };
    }
  }

  // Function to initialize theme UI elements
  function initializeThemeUI() {
    updateThemeIcon();
    attachThemeToggleHandler();
    // Initial favicon update is handled in the IIFE above
  }

  // Event listeners to initialize theme UI on initial load and after page swaps
  document.addEventListener('DOMContentLoaded', initializeThemeUI);
  document.addEventListener('astro:after-swap', initializeThemeUI);
</script>

<!-- Umami Analytics -->
{
  import.meta.env.PROD && (
    <script
      async
      defer
      is:inline
      data-website-id={SITE.umamiId}
      src="https://cloud.umami.is/script.js"
    />
  )
}

<!-- FeedbackFish -->
<script
  defer
  is:inline
  src="https://feedback.fish/ff.js?pid=e8f83126219490"
></script>
