---
import defaultImage from '@/assets/images/david-d-lawson-profile.png';
import { SITE } from '@/site.config';
import type { MetaSEO } from '@/types';
import { getRelativeUrlByFilePath } from '@/utils/directories';
import { AstroSeo } from '@astrolib/seo';
import { Font } from 'astro:assets';

export interface Props extends MetaSEO {
  dontUseTitleTemplate?: boolean;
}

const {
  title = SITE.name,
  description = SITE.description,
  image: _image = defaultImage,
  canonical = Astro.url.pathname,
  noindex = false,
  nofollow = false,
  ogTitle = title,
  ogType = 'website',
  dontUseTitleTemplate = false,
} = Astro.props;

const image =
  typeof _image === 'string'
    ? new URL(_image, Astro.site)
    : _image && typeof _image['src'] !== 'undefined'
      ? new URL(getRelativeUrlByFilePath(_image.src), Astro.site)
      : null;

const appleTouchIcon = {
  src: new URL('/favicon.png?theme=dark&width=192&height=192', Astro.site),
};
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width" />

<Font cssVariable="--font-switzer" preload />

<AstroSeo
  title={title}
  titleTemplate={dontUseTitleTemplate ? '%s' : `%s — ${SITE.name}`}
  description={description}
  canonical={String(canonical)}
  noindex={noindex}
  nofollow={nofollow}
  openGraph={{
    url: String(canonical),
    title: ogTitle,
    description: description,
    type: ogType,
    images: image
      ? [
          {
            url: image.toString(),
            alt: ogTitle,
          },
        ]
      : undefined,
    site_name: 'David D Lawson',
  }}
  twitter={{
    handle: '@ddlawson',
    // site: '@site',
    cardType: image ? 'summary_large_image' : undefined,
  }}
/>

<!-- Dynamic SVG Favicon (light/dark mode switching via JS) -->
<link id="favicon-svg" rel="icon" href="/favicon.svg" type="image/svg+xml" />

<link rel="apple-touch-icon" href={appleTouchIcon.src} />
<meta name="apple-mobile-web-app-title" content="D Lawson" />
<link rel="manifest" href="/manifest.json" />

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- RSS Feed -->
<link rel="alternate" type="application/rss+xml" title=`${SITE.name} RSS Feed` href={new URL('rss.xml', Astro.site)} />

<!-- Light/dark mode & Favicon Switching -->
<script src="../utils/theme-handler.ts"></script>

<!-- Umami Analytics -->
{
  import.meta.env.PROD && (
    <script async defer is:inline data-website-id={SITE.umamiId} src="https://cloud.umami.is/script.js" />
  )
}

<!-- FeedbackFish -->
<script defer is:inline src="https://feedback.fish/ff.js?pid=e8f83126219490"></script>
