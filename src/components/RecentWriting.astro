---
const posts = [
	{ date: "Mar 2026", title: "The Gap Between Product and Customer", tag: "Strategy" },
	{ date: "Feb 2026", title: "Why Developer Experience Matters More Than Features", tag: "DevEx" },
	{ date: "Jan 2026", title: "Building in Public: Month One", tag: "Personal" },
	{ date: "Dec 2025", title: "Cloud Security in the Age of AI", tag: "Security" },
];
---

<section class="m-section m-reveal" id="writing">
	<div class="m-label">
		<span class="m-label-text">Recent Writing</span>
		<div class="m-label-line"></div>
	</div>

	<div class="m-posts">
		{posts.map((post) => (
			<a href="#" class="m-post">
				<span class="m-post-date">{post.date}</span>
				<span class="m-post-title">{post.title}</span>
				<span class="m-post-tag">{post.tag}</span>
			</a>
		))}
	</div>

	<a href="/writing" class="m-view-all">View all <span>&rarr;</span></a>
</section>

<style>
	.m-posts {
		display: flex;
		flex-direction: column;
	}

	.m-post {
		display: grid;
		grid-template-columns: 88px 1fr auto;
		gap: 1.75rem;
		align-items: center;
		padding: 1.25rem 1.25rem;
		border-bottom: 1px solid var(--m-border);
		text-decoration: none;
		color: inherit;
		transition: all 0.25s ease;
		margin: 0 -1.25rem;
		border-radius: 3px;
	}

	.m-post:first-child {
		border-top: 1px solid var(--m-border);
	}

	.m-post:hover {
		background: var(--m-blue-ghost);
		border-bottom-color: transparent;
	}

	.m-post:hover + .m-post {
		border-top-color: transparent;
	}

	.m-post-date {
		font-family: var(--m-display);
		font-size: 0.68rem;
		font-weight: 400;
		color: var(--m-text-muted);
		letter-spacing: 0.02em;
		transition: color 0.25s ease;
	}

	.m-post-title {
		font-family: var(--m-body);
		font-size: 0.95rem;
		font-weight: 400;
		color: var(--m-text);
		transition: color 0.25s ease;
	}

	.m-post:hover .m-post-title {
		color: var(--m-blue-bright);
	}

	.m-post:hover .m-post-date {
		color: var(--m-blue);
	}

	.m-post-tag {
		font-family: var(--m-display);
		font-size: 0.52rem;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--m-text-muted);
		border: 1px solid var(--m-border);
		padding: 0.2rem 0.55rem;
		border-radius: 2px;
		transition:
			border-color 0.25s ease,
			color 0.25s ease;
	}

	.m-post:hover .m-post-tag {
		border-color: var(--m-blue-ring);
		color: var(--m-blue-muted);
	}

	.m-view-all {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		margin-top: 1.75rem;
		font-size: 0.8rem;
		font-weight: 400;
		color: var(--m-blue);
		text-decoration: none;
		transition:
			gap 0.3s ease,
			color 0.3s ease;
	}

	.m-view-all:hover {
		gap: 0.75rem;
		color: var(--m-blue-bright);
	}

	@media (max-width: 768px) {
		.m-post {
			grid-template-columns: 1fr;
			gap: 0.25rem;
		}

		.m-post-date {
			order: 2;
		}

		.m-post-tag {
			display: none;
		}
	}
</style>
