---
import { getCollection } from "astro:content";
import PostCard from "@/components/PostCard.astro";
import { conf } from "@/site.config.ts";

const dateFmt = conf.blog.dateFormatter;

function formatDate(date: Date): string {
  return dateFmt.format(date);
}

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
---

<section class="m-section m-reveal" id="writing">
  <div class="m-label">
    <span
      class="font-display text-text-muted text-label font-semibold tracking-[0.24em] whitespace-nowrap uppercase"
      >Recent Writing</span
    >
    <div class="from-border-hover h-px flex-1 bg-linear-to-r to-transparent/80">
    </div>
  </div>

  <div class="flex flex-col">
    {
      posts.map((post, i) => (
        <PostCard post={post} formatDate={formatDate} index={i} />
      ))
    }
  </div>

  <a
    href="/writing"
    class="text-micro text-teal hover:text-teal-bright mt-7 inline-flex items-center gap-2 font-normal no-underline transition-all duration-300 hover:gap-3"
    >View all <span>&rarr;</span></a
  >
</section>
