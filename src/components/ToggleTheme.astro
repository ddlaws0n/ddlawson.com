---
import { Icon } from 'astro-icon/components';

export interface Props {
  label?: string;
  class?: string;
  iconClass?: string;
}

const {
  label = 'Toggle between Dark and Light mode',
  class:
    className = 'inline-block rounded-lg p-2.5 text-sm text-slate-500 hover:bg-sky-100 hover:text-sky-500 focus:outline-hidden focus:ring-4 focus:ring-slate-200 dark:text-slate-400 dark:hover:bg-slate-700 dark:focus:ring-slate-700',
  iconClass = 'w-6 h-6',
} = Astro.props;
---

<button
  type="button"
  class={className}
  aria-label={label}
  data-aw-toggle-color-scheme>
  <Icon
    id="theme-icon"
    name="tabler:moon"
    class={iconClass}
  />
</button>
