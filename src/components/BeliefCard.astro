---
import type { Belief } from '@/data/beliefs';

interface Props {
  belief: Belief;
}

const { belief } = Astro.props;
---

<div
  class="reveal relative overflow-hidden border border-border transition-[background,border-color] duration-400 hover:border-border-hover hover:bg-surface"
  style="padding: 3.5rem;"
>
  <span
    aria-hidden="true"
    class="pointer-events-none absolute -top-2 -right-2 font-display text-ghost leading-[0.8] font-extralight tracking-tighter text-text opacity-ghost"
  >
    {belief.number}
  </span>
  <h3 class="relative mb-4 font-display text-heading leading-[1.25] font-semibold text-text">
    {belief.titleParts.map((part) => (part.accent ? <span class="text-accent">{part.text}</span> : part.text))}
  </h3>
  <p class="relative font-body text-small leading-relaxed font-light text-text-secondary opacity-65">
    {belief.body}
  </p>
</div>
