---
import { Icon } from 'astro-icon/components';
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';

const button = tv({
  base: [
    'inline-flex items-center justify-center gap-2 rounded-md font-semibold whitespace-nowrap',
    '[&_svg]:size-5 [&_svg]:shrink-0 [&_svg]:opacity-50',
    'transition-colors duration-200',
    'focus-visible:outline-2 focus-visible:outline-offset-2',
    'disabled:pointer-events-none disabled:opacity-50',
  ],
  variants: {
    variant: {
      primary: [
        'border border-transparent bg-accent text-bg',
        'hover:bg-accent-bright',
        'focus-visible:outline-accent',
      ],
      secondary: [
        'border border-border text-text-secondary',
        'hover:border-border-hover hover:text-text',
        'focus-visible:outline-border',
      ],
      outline: [
        'border border-border bg-transparent text-text-secondary',
        'hover:border-accent hover:text-accent',
        'focus-visible:outline-border',
      ],
      ghost: [
        'border-transparent bg-transparent text-text-secondary',
        'hover:text-text',
        'focus-visible:outline-border',
      ],
    },
    size: {
      sm: 'h-8 px-4 py-2 text-sm',
      md: 'h-10 px-6 py-2 text-base',
      lg: 'h-12 px-8 py-3 text-lg',
      icon: 'h-10 w-10 p-2',
    },
  },
  defaultVariants: {
    variant: 'secondary',
    size: 'md',
  },
});

interface Props extends HTMLAttributes<'button'>, Omit<HTMLAttributes<'a'>, 'type'>, VariantProps<typeof button> {
  title?: string;
  link?: string;
  icon?: string;
  umami?: string;
}

const { link, title, umami, variant, size, icon, class: className, ...props } = Astro.props;

const Tag = link ? 'a' : 'button';
---

<Tag
  href={link}
  class:list={[button({ variant, size, class: className }), umami && `umami--click--${umami}`]}
  {...props}
>
  {icon && <Icon name={icon} />}
  {title && <span>{title}</span>}
  <slot />
</Tag>
