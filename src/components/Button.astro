---
import { Icon } from 'astro-icon/components';
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';

const button = tv({
  base: [
    'inline-flex items-center justify-center gap-2 rounded-md font-semibold whitespace-nowrap',
    '[&_svg]:size-5 [&_svg]:shrink-0 [&_svg]:opacity-50',
    'transition-colors duration-200',
    'focus-visible:outline-2 focus-visible:outline-offset-2',
    'disabled:pointer-events-none disabled:opacity-50',
  ],
  variants: {
    variant: {
      primary: [
        'border-sky-700 bg-sky-700 text-white',
        'hover:border-sky-800 hover:bg-sky-800',
        'focus-visible:outline-sky-500',
        'dark:border-sky-300 dark:bg-sky-300 dark:text-slate-900',
        'dark:hover:border-sky-400 dark:hover:bg-sky-400',
      ],
      secondary: [
        'border border-slate-300 bg-white text-sky-700',
        'hover:bg-slate-100 hover:text-slate-800',
        'focus-visible:outline-slate-500',
        'dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300',
        'dark:hover:border-slate-800 dark:hover:bg-slate-800 dark:hover:text-slate-200',
      ],
      outline: [
        'border border-slate-300 bg-transparent text-slate-900',
        'hover:bg-slate-100',
        'dark:border-slate-700 dark:text-slate-300',
        'dark:hover:bg-slate-800',
      ],
      ghost: [
        'border-transparent bg-transparent text-slate-900',
        'hover:bg-slate-100',
        'dark:text-slate-300 dark:hover:bg-slate-800',
      ],
    },
    size: {
      sm: 'h-8 px-4 py-2 text-sm',
      md: 'h-10 px-6 py-2 text-base',
      lg: 'h-12 px-8 py-3 text-lg',
      icon: 'h-10 w-10 p-2',
    },
  },
  defaultVariants: {
    variant: 'primary',
    size: 'md',
  },
});

interface Props extends HTMLAttributes<'button'>, Omit<HTMLAttributes<'a'>, 'type'>, VariantProps<typeof button> {
  title?: string;
  link?: string;
  icon?: string;
  umami?: string;
}

const { link, title, umami, variant, size, icon, class: className, ...props } = Astro.props;

const Tag = link ? 'a' : 'button';
---

<Tag
  href={link}
  class:list={[button({ variant, size, class: className }), umami && `umami--click--${umami}`]}
  {...props}
>
  {icon && <Icon name={icon} />}
  {title && <span>{title}</span>}
  <slot />
</Tag>
