---
import { NAV } from '@/config';
import ToggleTheme from '@/components/ToggleTheme.astro';
const isActive = (navPath: string) => {
  const pathname = new URL(Astro.request.url).pathname;
  return pathname === navPath || (pathname.startsWith(navPath) && navPath !== '/');
};
---

<header id="page-header">
  <div class="flex flex-none items-center py-6 lg:py-8">
    <div class="container mx-auto xl:max-w-7xl">
      <nav
        x-data="{ mobileMenuIsOpen: false }"
        x-on:click.away="mobileMenuIsOpen = false"
        class="relative flex items-center justify-between"
        aria-label="Main navigation">
        <!-- Site Title/Logo (if needed) -->
        <div class="text-2xl font-bold text-slate-900 dark:text-white">
          <a
            href="/"
            class="flex items-center">
            <span class="sr-only">David D Lawson</span>
          </a>
        </div>

        <!-- Desktop Menu -->
        <div class="hidden items-center justify-center space-x-8 md:flex md:space-x-10">
          {
            NAV.map(({ name, href }) => (
              <a
                href={href}
                class:list={[
                  'md:text-md relative text-base font-medium',
                  `${isActive(href) ? 'text-sky-600 dark:text-sky-200' : 'text-slate-900 hover:text-sky-600 dark:text-white dark:hover:text-sky-200'}`,
                ]}>
                <span>{name}</span>
                <span
                  class:list={[
                    'custom-cubic-bezier pointer-events-none absolute -bottom-1 left-0 h-0.5 bg-sky-500 transition-all dark:bg-sky-400',
                    `${isActive(href) ? 'w-full' : 'w-0'}`,
                  ]}
                  aria-hidden="true"
                />
              </a>
            ))
          }
        </div>

        <!-- Theme Toggle and Mobile Menu Button -->
        <div class="flex items-center space-x-4 px-4">
          <ToggleTheme iconClass="size-6" />

          <!-- Mobile Menu Button -->
          <button
            x-on:click="mobileMenuIsOpen = !mobileMenuIsOpen"
            x-bind:aria-expanded="mobileMenuIsOpen"
            type="button"
            class="text-slate-600 md:hidden dark:text-slate-400"
            aria-label="mobile menu">
            <svg
              x-cloak
              x-show="!mobileMenuIsOpen"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              aria-hidden="true"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              class="size-6">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
              ></path>
            </svg>
            <svg
              x-cloak
              x-show="mobileMenuIsOpen"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              aria-hidden="true"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              class="size-6">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6 18 18 6M6 6l12 12"
              ></path>
            </svg>
          </button>
        </div>

        <!-- Mobile Menu -->
        <div
          x-cloak
          x-show="mobileMenuIsOpen"
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 -translate-y-4"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100 translate-y-0"
          x-transition:leave-end="opacity-0 -translate-y-4"
          class="absolute top-full right-0 left-0 z-20 mt-2 w-full origin-top-right rounded-md bg-white p-4 shadow-lg md:hidden dark:bg-slate-800">
          <div class="flex flex-col space-y-4">
            {
              NAV.map(({ name, href }) => (
                <a
                  href={href}
                  class:list={[
                    'relative block py-2 text-base font-medium',
                    `${isActive(href) ? 'text-sky-600 dark:text-sky-200' : 'text-slate-900 hover:text-sky-600 dark:text-white dark:hover:text-sky-200'}`,
                  ]}>
                  <span>{name}</span>
                </a>
              ))
            }
          </div>
        </div>
      </nav>
    </div>
  </div>
</header>

<style>
  /* Add to ensure Alpine.js x-cloak works properly */
  [x-cloak] {
    display: none !important;
  }
</style>
