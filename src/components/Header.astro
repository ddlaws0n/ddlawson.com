---
import { NAV } from '@/config';
import ToggleTheme from '@/components/ToggleTheme.astro';
const isActive = (navPath: string) => {
  const pathname = new URL(Astro.request.url).pathname;
  return pathname === navPath || (pathname.startsWith(navPath) && navPath !== '/');
};
---

<header id="page-header">
  <div class="flex flex-none items-center py-6 lg:py-8">
    <div class="container mx-auto xl:max-w-7xl">
      <nav
        id="main-nav"
        class="relative flex items-center justify-between"
        aria-label="Main navigation">
        <!-- Site Title/Logo (if needed) -->
        <div class="text-2xl font-bold text-slate-900 dark:text-white">
          <a
            href="/"
            class="flex items-center">
            <span class="sr-only">David D Lawson</span>
          </a>
        </div>

        <!-- Desktop Menu -->
        <div class="hidden items-center justify-center space-x-8 md:flex md:space-x-10">
          {
            NAV.map(({ name, href }) => (
              <a
                href={href}
                class:list={[
                  'md:text-md relative text-base font-medium',
                  `${isActive(href) ? 'text-sky-600 dark:text-sky-200' : 'text-slate-900 hover:text-sky-600 dark:text-white dark:hover:text-sky-200'}`,
                ]}>
                <span>{name}</span>
                <span
                  class:list={[
                    'custom-cubic-bezier pointer-events-none absolute -bottom-1 left-0 h-0.5 bg-sky-500 transition-all dark:bg-sky-400',
                    `${isActive(href) ? 'w-full' : 'w-0'}`,
                  ]}
                  aria-hidden="true"
                />
              </a>
            ))
          }
        </div>

        <!-- Theme Toggle and Mobile Menu Button -->
        <div class="flex items-center space-x-4 px-4">
          <ToggleTheme iconClass="size-6" />

          <!-- Mobile Menu Button -->
          <button
            id="mobile-menu-toggle"
            type="button"
            class="text-slate-600 md:hidden dark:text-slate-400"
            aria-label="mobile menu"
            aria-expanded="false">
            <svg
              id="mobile-menu-open-icon"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              aria-hidden="true"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              class="size-6">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
              ></path>
            </svg>
            <svg
              id="mobile-menu-close-icon"
              style="display: none;"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              aria-hidden="true"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              class="size-6">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6 18 18 6M6 6l12 12"
              ></path>
            </svg>
          </button>
        </div>

        <!-- Mobile Menu -->
        <div
          id="mobile-menu"
          hidden
          class="mobile-menu absolute top-full right-0 left-0 z-20 mt-2 w-full origin-top-right rounded-md bg-white p-4 shadow-lg md:hidden dark:bg-slate-800">
          <div class="flex flex-col space-y-4">
            {
              NAV.map(({ name, href }) => (
                <a
                  href={href}
                  class:list={[
                    'relative block py-2 text-base font-medium',
                    `${isActive(href) ? 'text-sky-600 dark:text-sky-200' : 'text-slate-900 hover:text-sky-600 dark:text-white dark:hover:text-sky-200'}`,
                  ]}>
                  <span>{name}</span>
                </a>
              ))
            }
          </div>
        </div>
      </nav>
    </div>
  </div>
</header>

<style>
  .mobile-menu[hidden] {
    display: none !important;
  }
  .mobile-menu {
    opacity: 0;
    transform: translateY(-1rem);
    transition:
      opacity 0.2s ease,
      transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }
  .mobile-menu.show {
    display: block !important;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    transition:
      opacity 0.2s ease,
      transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>

<script>
  // Vanilla JS mobile menu logic with TS safety
  const nav = document.getElementById('main-nav');
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('mobile-menu-open-icon');
  const closeIcon = document.getElementById('mobile-menu-close-icon');
  let mobileMenuIsOpen = false;

  function setMenuState(open: boolean) {
    mobileMenuIsOpen = open;
    if (!menu || !toggleBtn || !openIcon || !closeIcon) return;
    if (mobileMenuIsOpen) {
      menu.hidden = false;
      menu.classList.add('show');
      toggleBtn.setAttribute('aria-expanded', 'true');
      openIcon.style.display = 'none';
      closeIcon.style.display = '';
      // Trap focus inside menu if needed
    } else {
      menu.classList.remove('show');
      setTimeout(() => {
        if (menu) menu.hidden = true;
      }, 200);
      toggleBtn.setAttribute('aria-expanded', 'false');
      openIcon.style.display = '';
      closeIcon.style.display = 'none';
    }
  }

  if (toggleBtn) {
    toggleBtn.addEventListener('click', (_e) => {
      setMenuState(!mobileMenuIsOpen);
    });
  }

  // Click outside to close
  document.addEventListener('click', (e) => {
    if (!nav || !nav.contains(e.target as Node)) {
      if (mobileMenuIsOpen) setMenuState(false);
    }
  });

  // ESC to close
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenuIsOpen) {
      setMenuState(false);
    }
  });
</script>
